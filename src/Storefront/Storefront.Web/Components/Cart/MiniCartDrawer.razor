@using Storefront.Web.Services.Media

<aside class="mini-cart-drawer" aria-labelledby="mini-cart-title">
    <header class="mini-cart-header">
        <div>
            <p class="section-eyebrow accent">@Eyebrow</p>
            <h2 id="mini-cart-title">@Title</h2>
        </div>
        @if (ShowCloseButton)
        {
            <button class="mini-cart-close" type="button" aria-label="@CloseButtonLabel">@CloseButtonText</button>
        }
    </header>

    <div class="mini-cart-items">
        @if (Items.Count == 0)
        {
            <p class="empty-state">Your cart is currently empty.</p>
        }
        else
        {
            @foreach (var item in Items)
            {
                <article class="mini-cart-item">
                    <div class="mini-cart-thumb">
                        <div class="mini-cart-thumb-frame">
                            <div class="mini-cart-thumb-placeholder" aria-hidden="true"></div>
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <ResponsiveImage
                                    Source="@item.ImageUrl"
                                    Alt="@item.Name"
                                    Preset="MediaImagePreset.ProductCard"
                                    CssClass="mini-cart-thumb-image"
                                    HideOnError="true" />
                            }
                        </div>
                    </div>
                    <div class="mini-cart-item-copy">
                        <h3>@item.Name</h3>
                        <p class="tech-inline-meta">@item.Meta</p>
                        <strong>@FormatPrice(item.Amount, item.Currency)</strong>
                    </div>
                </article>
            }
        }
    </div>

    <footer class="mini-cart-footer">
        <div class="mini-cart-total-row">
            <span>Subtotal</span>
            <strong>@FormatPrice(Subtotal, Currency)</strong>
        </div>
        <p class="mini-cart-note">Taxes and shipping are calculated at checkout.</p>
        @if (ShowPrimaryAction)
        {
            <a class="tech-button tech-button-primary tech-button-block" href="@PrimaryActionHref">@PrimaryActionLabel</a>
        }

        @if (ShowSecondaryAction)
        {
            <a class="tech-button tech-button-ghost tech-button-block" href="@SecondaryActionHref">@SecondaryActionLabel</a>
        }
    </footer>
</aside>

@code {
    [Parameter]
    public IReadOnlyCollection<MiniCartLine> Items { get; set; } = [];

    [Parameter]
    public decimal Subtotal { get; set; }

    [Parameter]
    public string Currency { get; set; } = "EUR";

    [Parameter]
    public string Eyebrow { get; set; } = "Mini cart";

    [Parameter]
    public string Title { get; set; } = "Your cart";

    [Parameter]
    public bool ShowCloseButton { get; set; }

    [Parameter]
    public string CloseButtonLabel { get; set; } = "Close mini cart";

    [Parameter]
    public string CloseButtonText { get; set; } = "Close";

    [Parameter]
    public bool ShowPrimaryAction { get; set; } = true;

    [Parameter]
    public string PrimaryActionHref { get; set; } = "/checkout";

    [Parameter]
    public string PrimaryActionLabel { get; set; } = "Checkout";

    [Parameter]
    public bool ShowSecondaryAction { get; set; } = true;

    [Parameter]
    public string SecondaryActionHref { get; set; } = "/cart";

    [Parameter]
    public string SecondaryActionLabel { get; set; } = "View cart";

    public sealed record MiniCartLine(string Name, string Meta, decimal Amount, string Currency, string? ImageUrl);

    private static string FormatPrice(decimal amount, string currency)
    {
        return $"{amount:0.00} {currency}";
    }
}

@using Storefront.Web.Services.Media

<article class="category-card">
    <a class="category-card-link" href="@Href">
        <div class="category-card-media">
            @if (!string.IsNullOrWhiteSpace(ImageUrl))
            {
                <div class="category-card-image-frame">
                    <div class="category-card-placeholder" aria-hidden="true">
                        <div class="category-card-placeholder-glow"></div>
                    </div>
                    <ResponsiveImage
                        Source="@ImageUrl"
                        Alt="@Name"
                        Preset="MediaImagePreset.ProductHero"
                        CssClass="category-card-image category-card-image-live"
                        HideOnError="true" />
                </div>
            }
            else
            {
                <div class="category-card-placeholder" aria-hidden="true">
                    <div class="category-card-placeholder-glow"></div>
                </div>
            }
        </div>
        <div class="category-card-copy">
            <p class="category-card-kicker">@Eyebrow</p>
            <h3>@Name</h3>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <p>@Description</p>
            }
            <span class="category-card-cta">@CtaLabel</span>
        </div>
    </a>
</article>

@code {
    [Parameter]
    public string Name { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public string? ImageUrl { get; set; }

    [Parameter]
    public string Href { get; set; } = "/search";

    [Parameter]
    public string Eyebrow { get; set; } = "Collection";

    [Parameter]
    public string CtaLabel { get; set; } = "Explore collection";
}

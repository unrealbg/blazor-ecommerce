@using Storefront.Web.Services.Api
@using Storefront.Web.Services.Media

<section class="product-grid">
    @if (Items.Count == 0)
    {
        <section class="tech-empty-panel tech-grid-empty">
            <p class="tech-eyebrow">@EmptyEyebrow</p>
            <h2>@EmptyTitle</h2>
            <p>@EmptyMessage</p>
        </section>
    }
    else
    {
        @foreach (var product in Items)
        {
            <ProductCard Item="product" Preset="@Preset" />
        }
    }
</section>

@code {
    [Parameter]
    public IReadOnlyCollection<StoreSearchProductItem> Items { get; set; } = [];

    [Parameter]
    public string EmptyMessage { get; set; } = "No products found.";

    [Parameter]
    public string EmptyEyebrow { get; set; } = "No results";

    [Parameter]
    public string EmptyTitle { get; set; } = "No matching products right now.";

    [Parameter]
    public MediaImagePreset Preset { get; set; } = MediaImagePreset.ProductCard;
}

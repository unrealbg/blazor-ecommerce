@using Storefront.Web.Services.Media
@inject IMediaUrlService MediaUrlService
@inject NavigationManager NavigationManager

@if (!string.IsNullOrWhiteSpace(imageSource))
{
    <img
        class="@CssClass"
        src="@imageSource"
        srcset="@imageSrcSet"
        sizes="@resolvedSizes"
        alt="@Alt"
        width="@imageWidth"
        height="@imageHeight"
        loading="@loadingMode"
        decoding="@decodingMode"
        fetchpriority="@fetchPriority"
        @attributes="mergedAttributes" />
}

@code {
    [Parameter]
    public string? Source { get; set; }

    [Parameter]
    public string Alt { get; set; } = string.Empty;

    [Parameter]
    public MediaImagePreset Preset { get; set; } = MediaImagePreset.Inline;

    [Parameter]
    public int? Width { get; set; }

    [Parameter]
    public int? Height { get; set; }

    [Parameter]
    public bool Priority { get; set; }

    [Parameter]
    public string? CssClass { get; set; }

    [Parameter]
    public string? Sizes { get; set; }

    [Parameter]
    public bool HideOnError { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string imageSource = string.Empty;
    private string imageSrcSet = string.Empty;
    private string resolvedSizes = "100vw";
    private string loadingMode = "lazy";
    private string decodingMode = "async";
    private string fetchPriority = "auto";
    private string fallbackImageSource = string.Empty;
    private int? imageWidth;
    private int? imageHeight;
    private IReadOnlyDictionary<string, object>? mergedAttributes;

    protected override void OnParametersSet()
    {
        var definition = ResolveDefinition(this.Preset, this.Width, this.Height);

        this.imageWidth = definition.Width;
        this.imageHeight = definition.Height;
        this.resolvedSizes = string.IsNullOrWhiteSpace(this.Sizes) ? definition.Sizes : this.Sizes;

        this.loadingMode = this.Priority ? "eager" : "lazy";
        this.decodingMode = this.Priority ? "sync" : "async";
        this.fetchPriority = this.Priority ? "high" : "auto";
        this.fallbackImageSource = "/images/og-default.jpg";

        if (string.IsNullOrWhiteSpace(this.Source))
        {
            this.imageSource = this.fallbackImageSource;
            this.imageSrcSet = string.Empty;
            this.mergedAttributes = BuildAttributes();
            return;
        }

        var srcSetEntries = new List<string>(definition.Widths.Length);
        foreach (var width in definition.Widths)
        {
            var variantHeight = definition.FixedHeightForWidth(width);
            var url = BuildUrl(width, variantHeight);
            srcSetEntries.Add($"{url} {width}w");
        }

        this.imageSource = BuildUrl(definition.Width, definition.Height);
        this.imageSrcSet = string.Join(", ", srcSetEntries);
        this.mergedAttributes = BuildAttributes();
    }

    private string BuildUrl(int width, int? height)
    {
        if (TryBuildDirectStaticUrl(this.Source, out var directStaticUrl))
        {
            return directStaticUrl;
        }

        return this.Preset switch
        {
            MediaImagePreset.ProductCard => MediaUrlService.ProductImage(this.Source ?? string.Empty, width, height),
            MediaImagePreset.ProductHero => MediaUrlService.ProductImage(this.Source ?? string.Empty, width, height),
            MediaImagePreset.BlogCard => MediaUrlService.BlogCover(this.Source ?? string.Empty, width, height),
            MediaImagePreset.BlogHero => MediaUrlService.BlogCover(this.Source ?? string.Empty, width, height),
            _ => MediaUrlService.ContentInline(this.Source ?? string.Empty, width),
        };
    }

    private IReadOnlyDictionary<string, object>? BuildAttributes()
    {
        Dictionary<string, object>? attributes = null;

        if (this.AdditionalAttributes is not null && this.AdditionalAttributes.Count != 0)
        {
            attributes = new Dictionary<string, object>(this.AdditionalAttributes, StringComparer.OrdinalIgnoreCase);
        }

        if (this.HideOnError)
        {
            attributes ??= new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase);
            attributes["onerror"] = "this.onerror=null;this.style.display='none';";
        }
        else if (!string.IsNullOrWhiteSpace(this.fallbackImageSource))
        {
            attributes ??= new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase);
            var escapedFallback = this.fallbackImageSource
                .Replace("\\", "\\\\", StringComparison.Ordinal)
                .Replace("'", "\\'", StringComparison.Ordinal);
            attributes["onerror"] = $"this.onerror=null;this.src='{escapedFallback}';this.srcset='';";
        }

        return attributes;
    }

    private bool TryBuildDirectStaticUrl(string? source, out string directUrl)
    {
        directUrl = string.Empty;

        if (string.IsNullOrWhiteSpace(source))
        {
            return false;
        }

        var normalizedSource = source.Trim().Replace('\\', '/');
        if (normalizedSource.StartsWith("/images/", StringComparison.OrdinalIgnoreCase))
        {
            directUrl = normalizedSource;
            return true;
        }

        if (normalizedSource.StartsWith("images/", StringComparison.OrdinalIgnoreCase))
        {
            directUrl = $"/{normalizedSource}";
            return true;
        }

        if (Uri.TryCreate(normalizedSource, UriKind.Absolute, out var absoluteUri) &&
            Uri.TryCreate(NavigationManager.BaseUri, UriKind.Absolute, out var siteBaseUri) &&
            string.Equals(absoluteUri.Host, siteBaseUri.Host, StringComparison.OrdinalIgnoreCase) &&
            absoluteUri.AbsolutePath.StartsWith("/images/", StringComparison.OrdinalIgnoreCase))
        {
            directUrl = absoluteUri.PathAndQuery;
            return true;
        }

        return false;
    }

    private static PresetDefinition ResolveDefinition(MediaImagePreset preset, int? widthOverride, int? heightOverride)
    {
        var baseDefinition = preset switch
        {
            MediaImagePreset.ProductCard => new PresetDefinition(480, null, "(max-width: 720px) 48vw, (max-width: 1100px) 32vw, 240px", [320, 480, 640]),
            MediaImagePreset.ProductHero => new PresetDefinition(1200, null, "(max-width: 900px) 100vw, 720px", [640, 960, 1200]),
            MediaImagePreset.BlogCard => new PresetDefinition(640, 360, "(max-width: 720px) 100vw, 320px", [320, 640, 960]),
            MediaImagePreset.BlogHero => new PresetDefinition(1200, 630, "100vw", [640, 960, 1200]),
            _ => new PresetDefinition(1200, null, "(max-width: 960px) 100vw, 960px", [640, 960, 1200]),
        };

        var normalizedWidth = widthOverride is > 0 ? widthOverride.Value : baseDefinition.Width;
        var normalizedHeight = heightOverride is > 0
            ? heightOverride
            : baseDefinition.Height;

        var widths = baseDefinition.Widths
            .Where(width => width <= normalizedWidth)
            .Distinct()
            .Order()
            .ToList();

        if (!widths.Contains(normalizedWidth))
        {
            widths.Add(normalizedWidth);
        }

        return baseDefinition with
        {
            Width = normalizedWidth,
            Height = normalizedHeight,
            Widths = [.. widths.Order()],
        };
    }

    private sealed record PresetDefinition(
        int Width,
        int? Height,
        string Sizes,
        int[] Widths)
    {
        public int? FixedHeightForWidth(int width)
        {
            if (this.Height is null || this.Width <= 0)
            {
                return null;
            }

            return (int)Math.Round(this.Height.Value * (width / (double)this.Width));
        }
    }
}

@inject Storefront.Web.Services.Api.IStoreApiClient StoreApiClient
@inject Storefront.Web.Services.Customer.ICustomerContext CustomerContext
@inject Storefront.Web.Services.CartState CartState

<div class="add-to-cart">
    <label>
        Qty
        <input type="number" min="1" @bind="quantity" />
    </label>
    <button type="button" class="btn-primary" @onclick="AddToCartAsync" disabled="@Disabled">Add to Cart</button>
</div>

@if (!string.IsNullOrWhiteSpace(message))
{
    <p class="status-message">@message</p>
}

@code {
    private int quantity = 1;
    private string? message;

    [Parameter]
    public Guid ProductId { get; set; }

    [Parameter]
    public Guid? VariantId { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string DisabledMessage { get; set; } = "Item cannot be added to cart right now.";

    private async Task AddToCartAsync()
    {
        if (Disabled)
        {
            message = DisabledMessage;
            return;
        }

        if (quantity <= 0)
        {
            message = "Quantity must be greater than zero.";
            return;
        }

        var customerId = CustomerContext.GetCustomerId();
        var success = VariantId is { } variantId && variantId != Guid.Empty
            ? await StoreApiClient.AddItemToCartAsync(customerId, ProductId, variantId, quantity, CancellationToken.None)
            : await StoreApiClient.AddItemToCartAsync(customerId, ProductId, quantity, CancellationToken.None);

        if (!success)
        {
            message = "Could not add item to cart.";
            return;
        }

        CartState.Increase(quantity);
        message = "Item added to cart.";
    }
}

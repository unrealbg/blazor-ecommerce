@page "/account/questions"
@layout Storefront.Web.Components.Layout.AccountLayout
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient

<PageTitle>My Questions</PageTitle>

@if (isLoading)
{
    <header class="account-page-header account-page-intro">
        <p class="account-eyebrow">Account</p>
        <h1>Questions</h1>
        <p>Manage your product questions and answers.</p>
    </header>

    <section class="account-card account-state-card">
        <h2>Loading questions</h2>
        <p>We are fetching submitted questions and available answers.</p>
    </section>
}
else if (!isAuthenticated)
{
    <section class="account-card account-empty-state">
        <div class="account-empty-state-header">
            <p class="account-eyebrow">Account</p>
            <h1>Questions</h1>
            <p>Manage your product questions and answers.</p>
        </div>
        <div class="account-empty-prompt">
            <h2>Sign in to manage questions</h2>
            <p>Use your account to see product questions, answers and status.</p>
        </div>
        <div class="account-empty-actions">
            <a class="account-button account-button-primary" href="/account/login">Sign in</a>
            <a class="account-button account-button-secondary" href="/account/register">Create account</a>
        </div>
        <ul class="account-benefit-list" aria-label="Question options after sign in">
            <li class="account-benefit-item">View submitted product questions</li>
            <li class="account-benefit-item">Read answers from the store team</li>
            <li class="account-benefit-item">Check question and answer status</li>
        </ul>
    </section>
}
else if (questions.Count == 0)
{
    <header class="account-page-header account-page-intro">
        <p class="account-eyebrow">Account</p>
        <h1>Questions</h1>
        <p>Manage your product questions and answers.</p>
    </header>

    <section class="account-card account-state-card">
        <h2>Your submitted questions will appear here.</h2>
        <p>Once you ask about a product, replies and official answers will stay available in this view.</p>
        <div class="account-actions account-state-actions">
            <a class="account-button account-button-primary" href="/search">Browse products</a>
            <a class="account-button account-button-secondary" href="/account/orders">View orders</a>
        </div>
    </section>
}
else
{
    <header class="account-page-header account-page-intro">
        <p class="account-eyebrow">Account</p>
        <h1>Questions</h1>
        <p>Manage your product questions and answers.</p>
    </header>

    <div class="order-list">
        @foreach (var question in questions)
        {
            <article class="account-card account-order-card">
                <header class="account-card-header">
                    <div>
                        <p class="account-eyebrow">Product question</p>
                        <h2><a href="/product/@question.ProductSlug">@question.ProductName</a></h2>
                    </div>
                    <span class="account-chip account-chip-muted account-status-chip">@question.Status</span>
                </header>
                <p class="account-meta">@question.CreatedAtUtc.ToString("yyyy-MM-dd")</p>
                <p>@question.QuestionText</p>

                @if (question.Answers.Count > 0)
                {
                    <ul class="account-answer-list">
                        @foreach (var answer in question.Answers)
                        {
                            <li class="account-answer-item">
                                <div class="account-card-meta">
                                    <strong>@answer.DisplayName</strong>
                                @if (answer.IsOfficialAnswer)
                                {
                                        <span class="account-chip account-chip-accent">Official answer</span>
                                }
                                </div>
                                <p>@answer.AnswerText</p>
                                <p class="account-meta">Status: @answer.Status</p>
                            </li>
                        }
                    </ul>
                }

                <div class="account-actions account-card-actions">
                    <a class="account-button account-button-secondary" href="/product/@question.ProductSlug">Open product</a>
                </div>
            </article>
        }
    </div>
}

@code {
    private IReadOnlyCollection<StoreMyQuestion> questions = [];
    private bool isLoading = true;
    private bool isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        var customer = await StoreApiClient.GetCurrentCustomerAsync(CancellationToken.None);
        isAuthenticated = customer is not null;
        if (isAuthenticated)
        {
            questions = await StoreApiClient.GetMyQuestionsAsync(CancellationToken.None);
        }

        isLoading = false;
    }
}

@page "/account/questions"
@layout Storefront.Web.Components.Layout.AccountLayout
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient

<PageTitle>My Questions</PageTitle>

<section class="tech-panel account-page-intro">
    <p class="tech-eyebrow">Questions</p>
    <h1>Keep product questions, replies, and official answers in the same private client area.</h1>
    <p class="tech-copy">Questions asked before or after purchase remain visible without dropping into a support-dashboard experience.</p>
</section>

@if (isLoading)
{
    <section class="tech-detail-card account-state-card">
        <p class="tech-eyebrow">Loading</p>
        <h2>Preparing your questions</h2>
        <p>We are fetching submitted questions and available answers.</p>
    </section>
}
else if (!isAuthenticated)
{
    <section class="tech-detail-card account-state-card">
        <p class="tech-eyebrow">Sign in required</p>
        <h2>Access your product questions</h2>
        <p>Sign in to view answers and moderation status for previous questions.</p>
        <div class="account-state-actions">
            <a class="tech-button tech-button-primary" href="/account/login">Sign in</a>
            <a class="tech-button tech-button-ghost" href="/account/register">Create account</a>
        </div>
        <p class="account-state-support">Questions and official answers stay close to the products you are considering or already own.</p>
    </section>
}
else if (questions.Count == 0)
{
    <section class="tech-detail-card account-state-card">
        <p class="tech-eyebrow">No questions yet</p>
        <h2>Your submitted questions will appear here.</h2>
        <p>Once you ask about a product, replies and official answers will stay available in this view.</p>
        <div class="account-state-actions">
            <a class="tech-button tech-button-primary" href="/search">Explore the collection</a>
            <a class="tech-button tech-button-ghost" href="/account/orders">View orders</a>
        </div>
    </section>
}
else
{
    <div class="order-list">
        @foreach (var question in questions)
        {
            <article class="order-card account-order-card">
                <header class="account-card-header">
                    <div>
                        <p class="tech-eyebrow">Product question</p>
                        <h2><a href="/product/@question.ProductSlug">@question.ProductName</a></h2>
                    </div>
                    <span class="tech-chip tech-chip-muted account-status-chip">@question.Status</span>
                </header>
                <p class="tech-inline-meta">@question.CreatedAtUtc.ToString("yyyy-MM-dd")</p>
                <p>@question.QuestionText</p>

                @if (question.Answers.Count > 0)
                {
                    <ul class="account-answer-list">
                        @foreach (var answer in question.Answers)
                        {
                            <li class="account-answer-item">
                                <div class="account-card-meta">
                                    <strong>@answer.DisplayName</strong>
                                @if (answer.IsOfficialAnswer)
                                {
                                        <span class="tech-chip tech-chip-accent">Official answer</span>
                                }
                                </div>
                                <p>@answer.AnswerText</p>
                                <p class="tech-inline-meta">Status: @answer.Status</p>
                            </li>
                        }
                    </ul>
                }

                <div class="account-card-actions">
                    <a class="tech-inline-link" href="/product/@question.ProductSlug">Open product →</a>
                </div>
            </article>
        }
    </div>
}

@code {
    private IReadOnlyCollection<StoreMyQuestion> questions = [];
    private bool isLoading = true;
    private bool isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        var customer = await StoreApiClient.GetCurrentCustomerAsync(CancellationToken.None);
        isAuthenticated = customer is not null;
        if (isAuthenticated)
        {
            questions = await StoreApiClient.GetMyQuestionsAsync(CancellationToken.None);
        }

        isLoading = false;
    }
}

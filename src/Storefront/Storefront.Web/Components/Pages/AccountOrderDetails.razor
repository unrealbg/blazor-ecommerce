@page "/account/orders/{OrderId:guid}"
@layout Storefront.Web.Components.Layout.AccountLayout
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient

<PageTitle>Order Details</PageTitle>

<header class="account-page-header account-page-intro">
    <p class="account-eyebrow">Account</p>
    <h1>Order details</h1>
    <p>Review payment, delivery and item information for this order.</p>
</header>

@if (isLoading)
{
    <section class="account-card account-state-card">
        <h2>Preparing order details</h2>
        <p>We are fetching payment and shipment updates for this order.</p>
    </section>
}
else if (order is null)
{
    <section class="account-card account-state-card">
        <h2>Order not found</h2>
        <p>The requested order is unavailable or no longer accessible from this account.</p>
        <div class="account-actions account-state-actions">
            <a class="account-button account-button-primary" href="/account/orders">Back to orders</a>
            <a class="account-button account-button-secondary" href="/search">Browse products</a>
        </div>
    </section>
}
else
{
    <article class="account-card account-order-card">
        <header class="account-card-header">
            <div>
                <p class="account-eyebrow">Order summary</p>
                <h2>Order @order.Id</h2>
            </div>
            <span class="account-chip account-chip-muted account-status-chip">@order.Status</span>
        </header>
        <div class="account-detail-grid">
            <div>
                <span>Placed</span>
                <strong>@order.PlacedAtUtc.ToString("yyyy-MM-dd HH:mm")</strong>
            </div>
            <div>
                <span>Fulfilment</span>
                <strong>@order.FulfillmentStatus</strong>
            </div>
            <div>
                <span>Total</span>
                <strong>@FormatPrice(order.TotalAmount, order.Currency)</strong>
            </div>
            <div>
                <span>Shipping</span>
                <strong>@FormatPrice(order.ShippingPriceAmount, order.ShippingCurrency)</strong>
            </div>
        </div>
        <div class="account-detail-grid">
            <div>
                <span>Method</span>
                <strong>@order.ShippingMethodName</strong>
            </div>
            <div>
                <span>Code</span>
                <strong>@order.ShippingMethodCode</strong>
            </div>
        </div>
        <div class="account-actions account-card-actions">
            <a class="account-button account-button-secondary" href="/account/orders">Back to orders</a>
            <a class="account-button account-button-secondary" href="/search">Continue shopping</a>
        </div>
    </article>

    <section class="account-card account-form-card">
        <div class="account-card-header">
            <div>
                <p class="account-eyebrow">Payment</p>
                <h2>Payment summary</h2>
            </div>
        </div>

        @if (paymentIntent is null)
        {
            <p class="account-section-note">Payment will appear here once the provider session is created for this order.</p>
        }
        else
        {
            <div class="account-detail-grid">
                <div>
                    <span>Intent</span>
                    <strong>@paymentIntent.Id</strong>
                </div>
                <div>
                    <span>Provider</span>
                    <strong>@paymentIntent.Provider</strong>
                </div>
                <div>
                    <span>Status</span>
                    <strong>@paymentIntent.Status</strong>
                </div>
                <div>
                    <span>Amount</span>
                    <strong>@FormatPrice(paymentIntent.Amount, paymentIntent.Currency)</strong>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(paymentIntent.FailureMessage))
            {
                <p class="status-message warning">@paymentIntent.FailureMessage</p>
            }

            @if (RequiresPaymentAction(paymentIntent.Status))
            {
                <div class="account-actions account-card-actions">
                    <a class="account-button account-button-primary" href="@($"/checkout/payment?orderId={order.Id:D}")">Continue payment</a>
                </div>
            }
        }
    </section>

    <section class="account-card account-form-card">
        <div class="account-card-header">
            <div>
                <p class="account-eyebrow">Shipment</p>
                <h2>Delivery progress</h2>
            </div>
        </div>

        @if (shipment is null)
        {
            <p class="account-section-note">Delivery tracking will appear here as soon as the order enters fulfilment.</p>
        }
        else
        {
            <div class="account-detail-grid">
                <div>
                    <span>Status</span>
                    <strong>@shipment.Status</strong>
                </div>
                <div>
                    <span>Carrier</span>
                    <strong>@shipment.CarrierName</strong>
                </div>
                <div>
                    <span>Tracking</span>
                    <strong>@shipment.TrackingNumber</strong>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(shipment.TrackingUrl))
            {
                <div class="account-actions account-card-actions">
                    <a class="account-button account-button-secondary" href="@shipment.TrackingUrl" target="_blank" rel="noopener noreferrer">Track shipment</a>
                </div>
            }

            @if (shipment.Events.Count > 0)
            {
                <table class="cart-table account-event-table">
                    <thead>
                    <tr>
                        <th>Event</th>
                        <th>Message</th>
                        <th>Occurred</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var shipmentEvent in shipment.Events)
                    {
                        <tr>
                            <td>@shipmentEvent.EventType</td>
                            <td>@shipmentEvent.Message</td>
                            <td>@shipmentEvent.OccurredAtUtc.ToString("u")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        }
    </section>
}

@code {
    [Parameter]
    public Guid OrderId { get; set; }

    private bool isLoading = true;
    private StoreOrderSummary? order;
    private StorePaymentIntentDetails? paymentIntent;
    private StoreShipment? shipment;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        order = await StoreApiClient.GetOrderAsync(OrderId, CancellationToken.None);
        paymentIntent = await StoreApiClient.GetPaymentIntentByOrderAsync(OrderId, CancellationToken.None);
        shipment = await StoreApiClient.GetShipmentByOrderAsync(OrderId, CancellationToken.None);
        isLoading = false;
    }

    private static bool RequiresPaymentAction(string status)
    {
        return status.Equals("Pending", StringComparison.OrdinalIgnoreCase) ||
               status.Equals("Created", StringComparison.OrdinalIgnoreCase) ||
               status.Equals("RequiresAction", StringComparison.OrdinalIgnoreCase) ||
               status.Equals("Authorized", StringComparison.OrdinalIgnoreCase) ||
               status.Equals("Failed", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatPrice(decimal amount, string currency)
    {
        return string.Create(
            System.Globalization.CultureInfo.InvariantCulture,
            $"{amount:0.00} {currency.ToUpperInvariant()}");
    }
}

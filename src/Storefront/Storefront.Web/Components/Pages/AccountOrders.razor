@page "/account/orders"
@layout Storefront.Web.Components.Layout.AccountLayout
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient

<PageTitle>My Orders</PageTitle>

@if (isLoading)
{
    <header class="account-page-header account-page-intro">
        <p class="account-eyebrow">Account</p>
        <h1>Orders</h1>
        <p>View your order history and delivery status.</p>
    </header>

    <section class="account-card account-state-card">
        <h2>Loading orders</h2>
        <p>Fetching your order history.</p>
    </section>
}
else if (!isAuthenticated)
{
    <section class="account-card account-empty-state">
        <div class="account-empty-state-header">
            <p class="account-eyebrow">Account</p>
            <h1>Orders</h1>
            <p>View your order history and delivery status.</p>
        </div>
        <div class="account-empty-prompt">
            <h2>Sign in to view orders</h2>
            <p>Use your account to see order history, totals and delivery status.</p>
        </div>
        <div class="account-empty-actions">
            <a class="account-button account-button-primary" href="/account/login">Sign in</a>
            <a class="account-button account-button-secondary" href="/account/register">Create account</a>
        </div>
        <ul class="account-benefit-list" aria-label="Order options after sign in">
            <li class="account-benefit-item">Review recent orders</li>
            <li class="account-benefit-item">Check payment and delivery status</li>
            <li class="account-benefit-item">Open order details and line items</li>
        </ul>
    </section>
}
else if (orders.Count == 0)
{
    <header class="account-page-header account-page-intro">
        <p class="account-eyebrow">Account</p>
        <h1>Orders</h1>
        <p>View your order history and delivery status.</p>
    </header>

    <section class="account-card account-state-card">
        <h2>Your order history will appear here.</h2>
        <p>Once you place an order, payment details and shipment progress will be available in this area.</p>
        <div class="account-actions account-state-actions">
            <a class="account-button account-button-primary" href="/search">Browse products</a>
            <a class="account-button account-button-secondary" href="/cart">Open cart</a>
        </div>
    </section>
}
else
{
    <header class="account-page-header account-page-intro">
        <p class="account-eyebrow">Account</p>
        <h1>Orders</h1>
        <p>View your order history and delivery status.</p>
    </header>

    <section class="account-card account-overview-card">
        <div class="account-card-header">
            <div>
                <p class="account-eyebrow">Order snapshot</p>
                <h2>Your recent purchase history</h2>
            </div>
        </div>
        <div class="account-detail-grid account-detail-grid-emphasis">
            <div>
                <span>Total orders</span>
                <strong>@orders.Count</strong>
            </div>
            <div>
                <span>Total items</span>
                <strong>@orders.Sum(order => order.Lines.Count)</strong>
            </div>
            <div>
                <span>Latest order</span>
                <strong>@orders.OrderByDescending(order => order.PlacedAtUtc).First().PlacedAtUtc.ToString("yyyy-MM-dd")</strong>
            </div>
        </div>
    </section>

    <div class="order-list">
        @foreach (var order in orders)
        {
            <article class="account-card account-order-card">
                <header class="account-card-header">
                    <div>
                        <p class="account-eyebrow">Order overview</p>
                        <h2>Order @order.Id</h2>
                    </div>
                    <span class="account-chip account-chip-muted account-status-chip">@order.Status</span>
                </header>
                <div class="account-detail-grid">
                    <div>
                        <span>Placed</span>
                        <strong>@order.PlacedAtUtc.ToString("yyyy-MM-dd HH:mm")</strong>
                    </div>
                    <div>
                        <span>Total</span>
                        <strong>@FormatPrice(order.TotalAmount, order.Currency)</strong>
                    </div>
                    <div>
                        <span>Items</span>
                        <strong>@order.Lines.Count line@(order.Lines.Count == 1 ? string.Empty : "s")</strong>
                    </div>
                </div>
                <div class="account-actions account-card-actions">
                    <a class="account-button account-button-primary" href="@($"/account/orders/{order.Id:D}")">Open order</a>
                    <a class="account-button account-button-secondary" href="/search">Continue shopping</a>
                </div>
                <ul class="account-order-lines">
                    @foreach (var line in order.Lines)
                    {
                        <li>@line.Name × @line.Quantity</li>
                    }
                </ul>
            </article>
        }
    </div>
}

@code {
    private IReadOnlyCollection<StoreOrderSummary> orders = [];
    private bool isLoading = true;
    private bool isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        var profile = await StoreApiClient.GetCurrentCustomerAsync(CancellationToken.None);
        isAuthenticated = profile is not null;

        if (!isAuthenticated)
        {
            isLoading = false;
            return;
        }

        orders = await StoreApiClient.GetMyOrdersAsync(CancellationToken.None);
        isLoading = false;
    }

    private static string FormatPrice(decimal amount, string currency)
    {
        return $"{amount:0.00} {currency}";
    }
}

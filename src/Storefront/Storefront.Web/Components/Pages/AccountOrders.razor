@page "/account/orders"
@layout Storefront.Web.Components.Layout.AccountLayout
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient

<PageTitle>My Orders</PageTitle>

<section class="tech-panel account-page-intro">
    <p class="tech-eyebrow">Orders</p>
    <h1>Review every purchase, payment update, and fulfilment step from one calm order history.</h1>
    <p class="tech-copy">Totals, shipment progress, and line items stay visible in the same premium language as the storefront.</p>
</section>

@if (isLoading)
{
    <section class="tech-detail-card account-state-card">
        <p class="tech-eyebrow">Loading</p>
        <h2>Preparing your order history</h2>
        <p>We are fetching recent purchases and fulfilment updates.</p>
    </section>
}
else if (!isAuthenticated)
{
    <section class="tech-detail-card account-state-card">
        <p class="tech-eyebrow">Sign in required</p>
        <h2>Review your previous purchases</h2>
        <p>Sign in to view totals, payment status, and shipment progress.</p>
        <div class="account-state-actions">
            <a class="tech-button tech-button-primary" href="/account/login">Sign in</a>
            <a class="tech-button tech-button-ghost" href="/account/register">Create account</a>
        </div>
        <p class="account-state-support">Your private account keeps purchases, delivery status, and follow-up care in one place.</p>
    </section>
}
else if (orders.Count == 0)
{
    <section class="tech-detail-card account-state-card">
        <p class="tech-eyebrow">No orders yet</p>
        <h2>Your order history will appear here.</h2>
        <p>Once you place an order, payment details and shipment progress will be available in this area.</p>
        <div class="account-state-actions">
            <a class="tech-button tech-button-primary" href="/search">Browse hardware</a>
            <a class="tech-button tech-button-ghost" href="/cart">Open bag</a>
        </div>
    </section>
}
else
{
    <section class="tech-detail-card account-overview-card">
        <div class="account-card-header">
            <div>
                <p class="tech-eyebrow">Order snapshot</p>
                <h2>Your recent purchase history</h2>
            </div>
        </div>
        <div class="account-detail-grid account-detail-grid-emphasis">
            <div>
                <span>Total orders</span>
                <strong>@orders.Count</strong>
            </div>
            <div>
                <span>Total items</span>
                <strong>@orders.Sum(order => order.Lines.Count)</strong>
            </div>
            <div>
                <span>Latest order</span>
                <strong>@orders.OrderByDescending(order => order.PlacedAtUtc).First().PlacedAtUtc.ToString("yyyy-MM-dd")</strong>
            </div>
        </div>
    </section>

    <div class="order-list">
        @foreach (var order in orders)
        {
            <article class="order-card account-order-card">
                <header class="account-card-header">
                    <div>
                        <p class="tech-eyebrow">Order overview</p>
                        <h2>Order @order.Id</h2>
                    </div>
                    <span class="tech-chip tech-chip-muted account-status-chip">@order.Status</span>
                </header>
                <div class="account-detail-grid">
                    <div>
                        <span>Placed</span>
                        <strong>@order.PlacedAtUtc.ToString("yyyy-MM-dd HH:mm")</strong>
                    </div>
                    <div>
                        <span>Total</span>
                        <strong>@FormatPrice(order.TotalAmount, order.Currency)</strong>
                    </div>
                    <div>
                        <span>Items</span>
                        <strong>@order.Lines.Count line@(order.Lines.Count == 1 ? string.Empty : "s")</strong>
                    </div>
                </div>
                <div class="account-card-actions">
                    <a class="tech-button tech-button-primary" href="@($"/account/orders/{order.Id:D}")">Open order</a>
                    <a class="tech-inline-link" href="/search">Continue shopping →</a>
                </div>
                <ul class="account-order-lines">
                    @foreach (var line in order.Lines)
                    {
                        <li>@line.Name × @line.Quantity</li>
                    }
                </ul>
            </article>
        }
    </div>
}

@code {
    private IReadOnlyCollection<StoreOrderSummary> orders = [];
    private bool isLoading = true;
    private bool isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        var profile = await StoreApiClient.GetCurrentCustomerAsync(CancellationToken.None);
        isAuthenticated = profile is not null;

        if (!isAuthenticated)
        {
            isLoading = false;
            return;
        }

        orders = await StoreApiClient.GetMyOrdersAsync(CancellationToken.None);
        isLoading = false;
    }

    private static string FormatPrice(decimal amount, string currency)
    {
        return $"{amount:0.00} {currency}";
    }
}

@page "/product/{Slug}"
@rendermode InteractiveServer
@using Microsoft.Extensions.Options
@using Storefront.Web.Configuration
@using Storefront.Web.Services.Api
@using Storefront.Web.Services.Media
@using Storefront.Web.Services.Seo
@inject IStoreApiClient StoreApiClient
@inject ILogger<Product> Logger
@inject IPageMetadataService MetadataService
@inject IStructuredDataService StructuredDataService
@inject IMediaUrlService MediaUrlService
@inject IOptions<StorefrontFeatureFlagsOptions> FeatureFlags

<SeoHead Metadata="metadata" JsonLdScripts="jsonLdScripts" />

<div class="tech-product-page">
    <Breadcrumbs Items="breadcrumbs" />

    @if (isLoading)
    {
        <section class="tech-empty-panel">
            <p class="tech-eyebrow">Loading</p>
            <h1>Preparing product details</h1>
            <p>We are fetching the latest product information from the catalog.</p>
        </section>
    }
    else if (product is null || !product.IsActive || !string.Equals(product.Currency, "EUR", StringComparison.Ordinal))
    {
        <section class="tech-empty-panel">
            <p class="tech-eyebrow">Unavailable</p>
            <h1>Product not found</h1>
            <p>The requested product is currently unavailable or no longer part of the live collection.</p>
            <a class="tech-button tech-button-primary" href="/search">Browse the collection</a>
        </section>
    }
    else
    {
        <article class="product-details tech-product-details">
            <div class="product-gallery tech-product-gallery">
                <div class="tech-product-media-shell">
                    @if (!string.IsNullOrWhiteSpace(selectedImageUrl))
                    {
                        <ResponsiveImage
                            Source="@selectedImageUrl"
                            Alt="@selectedImageAlt"
                            Preset="MediaImagePreset.ProductHero"
                            CssClass="product-image"
                            Priority="true" />
                    }
                    else
                    {
                        <div class="tech-product-placeholder" aria-hidden="true"></div>
                    }
                </div>

                @if (galleryImages.Count > 1)
                {
                    <div class="product-gallery-thumbs tech-product-thumbs">
                        @foreach (var image in galleryImages)
                        {
                            var isSelectedImage = string.Equals(selectedImageUrl, image.SourceUrl, StringComparison.OrdinalIgnoreCase);
                            <button type="button" class="tech-thumb @(isSelectedImage ? "selected" : string.Empty)" @onclick="() => SelectImage(image.SourceUrl, image.AltText)">
                                <ResponsiveImage
                                    Source="@image.SourceUrl"
                                    Alt="@(image.AltText ?? product.Name)"
                                    Preset="MediaImagePreset.ProductCard"
                                    CssClass="card-image" />
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="product-copy tech-product-copy">
                <div class="tech-product-heading">
                    <p class="tech-eyebrow">@(product.CategoryName ?? product.Brand ?? "Flagship hardware")</p>
                    <div class="tech-product-title-row">
                        <h1>@product.Name</h1>
                        <span class="tech-chip @GetStockChipClass()">@GetStockStatusLabel()</span>
                    </div>
                    <div class="tech-product-meta">
                        @if (!string.IsNullOrWhiteSpace(product.Brand))
                        {
                            <span>@product.Brand</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(selectedSku))
                        {
                            <span>SKU @selectedSku</span>
                        }
                        @if (reviewSummary is not null && reviewSummary.ApprovedReviewCount > 0)
                        {
                            <span class="tech-review-meta">
                                <RatingStars Value="reviewSummary.AverageRating" />
                                <span>@reviewSummary.ApprovedReviewCount approved review(s)</span>
                            </span>
                        }
                    </div>
                </div>

                <p class="tech-product-description">
                    @(string.IsNullOrWhiteSpace(product.Description)
                        ? "Designed for shoppers who expect premium materials, disciplined detail, and clear technical positioning."
                        : product.Description)
                </p>

                <section class="tech-detail-card tech-purchase-panel">
                    <div class="tech-price-stack">
                        <div class="tech-price-row">
                            <span class="tech-price-current">@FormatPrice(selectedAmount, selectedCurrency)</span>
                            @if (selectedCompareAtAmount is > 0m && selectedCompareAtAmount > selectedAmount)
                            {
                                <span class="tech-price-compare">@FormatPrice(selectedCompareAtAmount.Value, selectedCurrency)</span>
                            }
                        </div>
                        <p class="tech-inline-meta">@GetAvailabilityDescription()</p>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(selectionMessage))
                    {
                        <p class="status-message warning">@selectionMessage</p>
                    }

                    <AddToCartButton
                        ProductId="product.Id"
                        VariantId="@(selectedVariant?.Id ?? product.DefaultVariantId)"
                        Disabled="@IsAddToCartDisabled()"
                        DisabledMessage="This product is currently out of stock."
                        @rendermode="InteractiveServer" />

                    <div class="tech-purchase-notes">
                        <span>Insured EU shipping</span>
                        <span>30-day returns</span>
                        <span>Secure checkout</span>
                    </div>
                </section>

                <div class="tech-spec-row">
                    <article class="tech-spec-item">
                        <span>Fulfilment</span>
                        <strong>24-48H</strong>
                        <small>insured EU dispatch</small>
                    </article>
                    <article class="tech-spec-item">
                        <span>Service</span>
                        <strong>CARE+</strong>
                        <small>returns and support guidance</small>
                    </article>
                    <article class="tech-spec-item">
                        <span>Packaging</span>
                        <strong>PREMIUM</strong>
                        <small>protected presentation</small>
                    </article>
                </div>

                @if (optionNames.Count > 0)
                {
                    <section class="tech-detail-card">
                        <div class="tech-detail-card-header">
                            <p class="tech-eyebrow">Configuration</p>
                            <h2>Choose your setup</h2>
                        </div>

                        <div class="tech-option-grid">
                            @foreach (var optionName in optionNames)
                            {
                                <label class="tech-field">
                                    <span>@optionName</span>
                                    <select value="@GetSelectedOptionValue(optionName)" @onchange="args => SelectOption(optionName, args.Value?.ToString())">
                                        @foreach (var value in GetOptionValues(optionName))
                                        {
                                            <option value="@value">@value</option>
                                        }
                                    </select>
                                </label>
                            }
                        </div>
                    </section>
                }
            </div>
        </article>

        @if (groupedAttributes.Count > 0)
        {
            <section class="tech-detail-card tech-detail-section">
                <div class="tech-section-header">
                    <div>
                        <p class="tech-eyebrow">Specifications</p>
                        <h2>Technical details presented with the same clarity as the product itself.</h2>
                    </div>
                </div>

                <div class="tech-spec-groups">
                    @foreach (var group in groupedAttributes)
                    {
                        <article class="tech-spec-group-card">
                            <h3>@group.Key</h3>
                            <table class="cart-table tech-spec-table">
                                <tbody>
                                    @foreach (var attribute in group.Value)
                                    {
                                        <tr>
                                            <th>@(attribute.Name)</th>
                                            <td>@(attribute.Value)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </article>
                    }
                </div>
            </section>
        }

        @if (product.RelatedProducts.Count > 0)
        {
            <section class="tech-section">
                <div class="tech-section-header">
                    <div>
                        <p class="tech-eyebrow">Featured collection</p>
                        <h2>Products that extend the same material and performance ecosystem.</h2>
                    </div>
                </div>

                <div class="product-grid">
                    @foreach (var related in product.RelatedProducts)
                    {
                        <article class="product-card">
                            <a class="product-card-media" href="/product/@related.Slug">
                                @if (!string.IsNullOrWhiteSpace(related.ImageUrl))
                                {
                                    <div class="product-card-image-frame">
                                        <div class="product-card-image product-card-placeholder" aria-hidden="true"></div>
                                        <ResponsiveImage
                                            Source="@related.ImageUrl"
                                            Alt="@related.Name"
                                            Preset="MediaImagePreset.ProductCard"
                                            CssClass="product-card-image product-card-image-live"
                                            HideOnError="true" />
                                    </div>
                                }
                                else
                                {
                                    <div class="product-card-image product-card-placeholder" aria-hidden="true"></div>
                                }
                            </a>
                            <div class="product-card-copy">
                                <p class="product-card-kicker">Recommended pairing</p>
                                <h3 class="product-card-title"><a href="/product/@related.Slug">@related.Name</a></h3>
                                <p class="product-card-description">Designed to complement the primary setup without adding visual clutter.</p>
                                <div class="product-card-meta-row">
                                    <span class="product-card-price">@FormatPrice(related.Amount, related.Currency)</span>
                                    <a class="product-card-cta" href="/product/@related.Slug">View details</a>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </section>
        }

        @if (reviewsEnabled)
        {
        <section class="tech-detail-card tech-detail-section">
            <div class="tech-section-header">
                <div>
                    <p class="tech-eyebrow">Review proof</p>
                    <h2>Ratings and reviews stay part of the product story, not an afterthought.</h2>
                </div>
            </div>

            @if (reviewSummary is null || reviewSummary.ApprovedReviewCount == 0)
            {
                <p class="empty-state tech-empty-state">No approved reviews yet.</p>
            }
            else
            {
                <div class="tech-review-summary">
                    <div class="tech-review-summary-score">
                        <p class="tech-price-current">@reviewSummary.AverageRating.ToString("0.0")/5</p>
                        <RatingStars Value="reviewSummary.AverageRating" />
                        <p>@reviewSummary.ApprovedReviewCount approved review(s)</p>
                    </div>
                    <div class="tech-review-bars">
                        @foreach (var star in Enumerable.Range(1, 5).Reverse())
                        {
                            var count = GetReviewCountForRating(star);
                            <div class="tech-review-bar">
                                <span>@star star</span>
                                <progress max="@Math.Max(1, reviewSummary.ApprovedReviewCount)" value="@count"></progress>
                                <span>@count</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="tech-toolbar">
                <label class="tech-field">
                    <span>Sort reviews</span>
                    <select @bind="reviewSort" @bind:after="LoadReviewsAsync">
                        <option value="newest">Newest</option>
                        <option value="most-helpful">Most helpful</option>
                    </select>
                </label>
                <label class="tech-field">
                    <span>Filter rating</span>
                    <select @bind="reviewRatingFilter" @bind:after="LoadReviewsAsync">
                        <option value="">All ratings</option>
                        <option value="5">5 stars</option>
                        <option value="4">4 stars</option>
                        <option value="3">3 stars</option>
                        <option value="2">2 stars</option>
                        <option value="1">1 star</option>
                    </select>
                </label>
            </div>

            @if (isReviewsLoading)
            {
                <p class="empty-state tech-empty-state">Loading reviews...</p>
            }
            else if (reviewPage.Items.Count == 0)
            {
                <p class="empty-state tech-empty-state">No reviews match the current filters.</p>
            }
            else
            {
                <div class="order-list tech-review-list">
                    @foreach (var review in reviewPage.Items)
                    {
                        <article class="order-card tech-review-card">
                            <header>
                                <div>
                                    <strong>@review.DisplayName</strong>
                                    @if (review.IsVerifiedPurchase)
                                    {
                                        <span class="tech-chip tech-chip-success">Verified purchase</span>
                                    }
                                </div>
                                <p>@review.CreatedAtUtc.ToString("yyyy-MM-dd")</p>
                            </header>
                            <RatingStars Value="review.Rating" />
                            @if (!string.IsNullOrWhiteSpace(review.Title))
                            {
                                <h3>@review.Title</h3>
                            }

                            @if (!string.IsNullOrWhiteSpace(review.VariantName))
                            {
                                <p class="tech-inline-meta">Reviewed variant: @review.VariantName</p>
                            }

                            @if (!string.IsNullOrWhiteSpace(review.Body))
                            {
                                <p>@review.Body</p>
                            }

                            <div class="cart-actions">
                                <button class="tech-button tech-button-ghost tech-button-compact" type="button" @onclick='() => VoteReviewAsync(review.Id, "Helpful")'>
                                    Helpful (@review.HelpfulCount)
                                </button>
                                <button class="tech-button tech-button-ghost tech-button-compact" type="button" @onclick='() => VoteReviewAsync(review.Id, "NotHelpful")'>
                                    Not helpful (@review.NotHelpfulCount)
                                </button>
                                @if (currentCustomer is not null)
                                {
                                    <button class="account-link-button account-link-button-danger" type="button" @onclick="() => ReportReviewAsync(review.Id)">
                                        Report
                                    </button>
                                }
                            </div>
                        </article>
                    }
                </div>

                <div class="pagination tech-pagination">
                    <button class="tech-button tech-button-ghost tech-button-compact" type="button" disabled="@(reviewPage.Page <= 1)" @onclick="PreviousReviewPageAsync">Previous</button>
                    <span class="page-indicator">Page @reviewPage.Page of @reviewPage.TotalPages</span>
                    <button class="tech-button tech-button-ghost tech-button-compact" type="button" disabled="@(reviewPage.Page >= reviewPage.TotalPages)" @onclick="NextReviewPageAsync">Next</button>
                </div>
            }

            <div class="tech-form-card">
                <h3>Write a review</h3>
                @if (currentCustomer is null)
                {
                    <div class="tech-auth-callout">
                        <p>You need to sign in to submit a review.</p>
                        <div class="account-state-actions">
                            <a class="tech-button tech-button-primary" href="/account/login">Sign in</a>
                            <a class="tech-button tech-button-ghost" href="/account/register">Create account</a>
                        </div>
                    </div>
                }
                else
                {
                    <EditForm Model="reviewForm" OnValidSubmit="SubmitReviewAsync">
                        <div class="form-grid tech-form-grid">
                            @if (product.Variants.Count > 1)
                            {
                                <label class="tech-field">
                                    <span>Variant</span>
                                    <select @bind="reviewForm.VariantId">
                                        <option value="">Default product</option>
                                        @foreach (var variant in product.Variants.Where(item => item.IsActive))
                                        {
                                            <option value="@variant.Id">@GetVariantLabel(variant)</option>
                                        }
                                    </select>
                                </label>
                            }
                            <label class="tech-field">
                                <span>Rating</span>
                                <select @bind="reviewForm.Rating">
                                    @foreach (var rating in Enumerable.Range(1, 5).Reverse())
                                    {
                                        <option value="@rating">@rating</option>
                                    }
                                </select>
                            </label>
                            <label class="tech-field">
                                <span>Title</span>
                                <InputText @bind-Value="reviewForm.Title" />
                            </label>
                            <label class="tech-field tech-field-full">
                                <span>Review</span>
                                <InputTextArea @bind-Value="reviewForm.Body" />
                            </label>
                        </div>
                        <button class="tech-button tech-button-primary" type="submit" disabled="@isSubmittingReview">Submit review</button>
                    </EditForm>
                }

                @if (!string.IsNullOrWhiteSpace(reviewMessage))
                {
                    <p class="status-message">@reviewMessage</p>
                }
            </div>
        </section>

        <section class="tech-detail-card tech-detail-section">
            <div class="tech-section-header">
                <div>
                    <p class="tech-eyebrow">Product Q&amp;A</p>
                    <h2>Keep buying questions close to the product, with clear public answers.</h2>
                </div>
            </div>

            @if (isQuestionsLoading)
            {
                <p class="empty-state tech-empty-state">Loading questions...</p>
            }
            else if (questionPage.Items.Count == 0)
            {
                <p class="empty-state tech-empty-state">No approved questions yet.</p>
            }
            else
            {
                <div class="order-list tech-question-list">
                    @foreach (var question in questionPage.Items)
                    {
                        <article class="order-card tech-question-card">
                            <header>
                                <strong>@question.DisplayName</strong>
                                <p>@question.CreatedAtUtc.ToString("yyyy-MM-dd")</p>
                            </header>
                            <p>@question.QuestionText</p>

                            @if (question.Answers.Count == 0)
                            {
                                <p class="tech-inline-meta">No public answers yet.</p>
                            }
                            else
                            {
                                <ul class="tech-answer-list">
                                    @foreach (var answer in question.Answers.Where(item => string.Equals(item.Status, "Approved", StringComparison.OrdinalIgnoreCase)))
                                    {
                                        <li>
                                            <div class="tech-answer-header">
                                                <strong>@answer.DisplayName</strong>
                                                @if (answer.IsOfficialAnswer)
                                                {
                                                    <span class="tech-chip tech-chip-accent">Official answer</span>
                                                }
                                            </div>
                                            <div>@answer.AnswerText</div>
                                        </li>
                                    }
                                </ul>
                            }

                            @if (currentCustomer is not null)
                            {
                                <div class="form-grid tech-form-grid">
                                    <label class="tech-field tech-field-full">
                                        <span>Add answer</span>
                                        <InputTextArea Value="@GetPendingAnswer(question.Id)" ValueChanged="value => SetPendingAnswer(question.Id, value)" />
                                    </label>
                                </div>
                                <button class="tech-button tech-button-ghost tech-button-compact" type="button" @onclick="() => SubmitAnswerAsync(question.Id)">Submit answer</button>
                            }
                        </article>
                    }
                </div>
            }

            <div class="pagination tech-pagination">
                <button class="tech-button tech-button-ghost tech-button-compact" type="button" disabled="@(questionPage.Page <= 1)" @onclick="PreviousQuestionPageAsync">Previous</button>
                <span class="page-indicator">Page @questionPage.Page of @questionPage.TotalPages</span>
                <button class="tech-button tech-button-ghost tech-button-compact" type="button" disabled="@(questionPage.Page >= questionPage.TotalPages)" @onclick="NextQuestionPageAsync">Next</button>
            </div>

            <div class="tech-form-card">
                <h3>Ask a question</h3>
                @if (currentCustomer is null)
                {
                    <div class="tech-auth-callout">
                        <p>You need to sign in to ask a question.</p>
                        <div class="account-state-actions">
                            <a class="tech-button tech-button-primary" href="/account/login">Sign in</a>
                            <a class="tech-button tech-button-ghost" href="/account/register">Create account</a>
                        </div>
                    </div>
                }
                else
                {
                    <EditForm Model="questionForm" OnValidSubmit="SubmitQuestionAsync">
                        <div class="form-grid tech-form-grid">
                            <label class="tech-field tech-field-full">
                                <span>Question</span>
                                <InputTextArea @bind-Value="questionForm.QuestionText" />
                            </label>
                        </div>
                        <button class="tech-button tech-button-primary" type="submit" disabled="@isSubmittingQuestion">Submit question</button>
                    </EditForm>
                }

                @if (!string.IsNullOrWhiteSpace(questionMessage))
                {
                    <p class="status-message">@questionMessage</p>
                }
            </div>
        </section>
        }
    }
</div>

@code {
    private const string DefaultOgImagePath = "/images/og-default.jpg";

    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private PageMetadata metadata = new("Product", "Product details page.", "/", false, "product");
    private IReadOnlyCollection<string> jsonLdScripts = [];
    private IReadOnlyList<BreadcrumbItem> breadcrumbs = [];
    private StoreProduct? product;
    private bool isLoading = true;
    private StoreProductVariant? selectedVariant;
    private string? selectedImageUrl;
    private string? selectedImageAlt;
    private string? selectionMessage;
    private StoreCustomerProfile? currentCustomer;
    private IReadOnlyCollection<StoreProductImage> galleryImages = [];
    private IReadOnlyDictionary<string, IReadOnlyCollection<string>> optionValueLookup =
        new Dictionary<string, IReadOnlyCollection<string>>();
    private IReadOnlyCollection<string> optionNames = [];
    private IReadOnlyDictionary<string, string> selectedOptions = new Dictionary<string, string>();
    private IReadOnlyDictionary<string, IReadOnlyCollection<StoreProductAttribute>> groupedAttributes =
        new Dictionary<string, IReadOnlyCollection<StoreProductAttribute>>();
    private StoreReviewSummary? reviewSummary;
    private StoreReviewPage reviewPage = new(1, 10, 0, 1, []);
    private StoreQuestionPage questionPage = new(1, 10, 0, 1, []);
    private bool isReviewsLoading;
    private bool isQuestionsLoading;
    private bool isSubmittingReview;
    private bool isSubmittingQuestion;
    private string reviewSort = "newest";
    private string? reviewRatingFilter;
    private string? reviewMessage;
    private string? questionMessage;
    private ReviewFormModel reviewForm = new();
    private QuestionFormModel questionForm = new();
    private Dictionary<Guid, string> pendingAnswers = [];
    private bool reviewsEnabled;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        reviewsEnabled = FeatureFlags.Value.EnableReviews;
        metadata = BuildInitialMetadata();
        Logger.LogDebug("Loading product page for slug {Slug}.", Slug);

        product = await StoreApiClient.GetProductBySlugAsync(Slug, CancellationToken.None);
        currentCustomer = reviewsEnabled
            ? await StoreApiClient.GetCurrentCustomerAsync(CancellationToken.None)
            : null;
        if (product is null)
        {
            metadata = new PageMetadata(
                "Product not found",
                "Requested product does not exist.",
                MetadataService.BuildAbsoluteUrl($"/product/{Slug}"));
            breadcrumbs =
            [
                new BreadcrumbItem("Home", "/"),
                new BreadcrumbItem("Product not found", $"/product/{Slug}"),
            ];
            jsonLdScripts =
            [
                StructuredDataService.BuildBreadcrumbJsonLd(ToAbsoluteBreadcrumbs(breadcrumbs)),
            ];
            isLoading = false;
            return;
        }

        InitializeSelectionState(product);
        InitializeForms(product);
        if (reviewsEnabled)
        {
            await LoadReviewStateAsync(product.Id);
            await LoadQuestionStateAsync(product.Id);
        }
        else
        {
            reviewSummary = null;
            reviewPage = new StoreReviewPage(1, 10, 0, 1, []);
            questionPage = new StoreQuestionPage(1, 10, 0, 1, []);
        }

        var primaryImage = selectedImageUrl ?? product.ImageUrl ?? DefaultOgImagePath;
        var openGraphImage = ResolveOpenGraphImage(primaryImage);
        var productImageUrls = galleryImages
            .Select(image => MediaUrlService.ProductImage(image.SourceUrl ?? primaryImage, 1200))
            .Append(MediaUrlService.ProductImage(primaryImage, 1200))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();

        metadata = MetadataService.ForProduct(product.Name, product.Description, product.Slug) with
        {
            OpenGraphType = "product",
            OpenGraphImageUrl = openGraphImage,
        };
        breadcrumbs = BuildProductBreadcrumbs(product);

        var productJsonLd = StructuredDataService.BuildProductJsonLd(
            new ProductSeoModel(
                product.Name,
                product.Description,
                selectedCurrency,
                selectedAmount,
                selectedVariant?.IsInStock ?? product.IsInStock,
                selectedSku,
                product.Brand,
                productImageUrls,
                reviewSummary?.AverageRating,
                reviewSummary?.ApprovedReviewCount ?? 0),
            metadata.CanonicalUrl);

        jsonLdScripts =
        [
            productJsonLd,
            StructuredDataService.BuildBreadcrumbJsonLd(ToAbsoluteBreadcrumbs(breadcrumbs)),
        ];

        isLoading = false;
    }

    private decimal selectedAmount => selectedVariant?.Amount ?? product?.Amount ?? 0m;

    private decimal? selectedCompareAtAmount => selectedVariant?.CompareAtAmount ?? product?.CompareAtAmount;

    private string selectedCurrency => selectedVariant?.Currency ?? product?.Currency ?? "EUR";

    private string? selectedSku => selectedVariant?.Sku ?? product?.Sku;

    private static string FormatPrice(decimal amount, string currency)
    {
        return $"{amount:0.00} {currency}";
    }

    private int GetReviewCountForRating(int rating)
    {
        return rating switch
        {
            5 => reviewSummary?.FiveStarCount ?? 0,
            4 => reviewSummary?.FourStarCount ?? 0,
            3 => reviewSummary?.ThreeStarCount ?? 0,
            2 => reviewSummary?.TwoStarCount ?? 0,
            1 => reviewSummary?.OneStarCount ?? 0,
            _ => 0,
        };
    }

    private string GetStockStatusLabel()
    {
        if (selectedVariant is null)
        {
            return product?.IsInStock == true ? "In stock" : "Out of stock";
        }

        if (!selectedVariant.IsTracked)
        {
            return "In stock";
        }

        if (selectedVariant.AllowBackorder && selectedVariant.AvailableQuantity <= 0)
        {
            return "Backorder available";
        }

        return selectedVariant.IsInStock ? "In stock" : "Out of stock";
    }

    private string GetStockChipClass()
    {
        if (selectedVariant is null)
        {
            return product?.IsInStock == true ? "tech-chip-success" : "tech-chip-muted";
        }

        if (!selectedVariant.IsTracked)
        {
            return "tech-chip-success";
        }

        if (selectedVariant.AllowBackorder && selectedVariant.AvailableQuantity <= 0)
        {
            return "tech-chip-accent";
        }

        return selectedVariant.IsInStock ? "tech-chip-success" : "tech-chip-muted";
    }

    private string GetAvailabilityDescription()
    {
        if (selectedVariant is null)
        {
            return product?.IsInStock == true
                ? "Ready for dispatch with premium post-purchase support."
                : "Currently unavailable. Check back for the next stock allocation.";
        }

        if (!selectedVariant.IsTracked)
        {
            return "Available for purchase without tracked stock limits.";
        }

        if (selectedVariant.AllowBackorder && selectedVariant.AvailableQuantity <= 0)
        {
            return "Backorder is enabled for this configuration.";
        }

        if (selectedVariant.IsInStock && selectedVariant.AvailableQuantity is > 0)
        {
            return $"{selectedVariant.AvailableQuantity} unit(s) currently available.";
        }

        return "Currently unavailable. Try another configuration.";
    }

    private bool IsAddToCartDisabled()
    {
        if (selectedVariant is null)
        {
            return product?.IsInStock != true;
        }

        if (!selectedVariant.IsTracked)
        {
            return false;
        }

        return !selectedVariant.IsInStock && !selectedVariant.AllowBackorder;
    }

    private static IReadOnlyList<BreadcrumbItem> BuildProductBreadcrumbs(StoreProduct currentProduct)
    {
        var breadcrumbItems = new List<BreadcrumbItem> { new("Home", "/") };
        breadcrumbItems.AddRange(currentProduct.CategoryBreadcrumbs.Select(item => new BreadcrumbItem(item.Name, $"/category/{item.Slug}")));
        breadcrumbItems.Add(new BreadcrumbItem(currentProduct.Name, $"/product/{currentProduct.Slug}"));
        return breadcrumbItems;
    }

    private IEnumerable<BreadcrumbItem> ToAbsoluteBreadcrumbs(IEnumerable<BreadcrumbItem> source)
    {
        return source.Select(item => new BreadcrumbItem(item.Name, MetadataService.BuildAbsoluteUrl(item.Url)));
    }

    private PageMetadata BuildInitialMetadata()
    {
        return new PageMetadata(
            BuildFallbackProductTitle(Slug),
            "Explore specifications, pricing, and availability for this product.",
            MetadataService.BuildAbsoluteUrl($"/product/{Slug}"),
            false,
            "product",
            ResolveOpenGraphImage(DefaultOgImagePath));
    }

    private string ResolveOpenGraphImage(string? imageSource)
    {
        var resolved = SeoImageMetadata.ResolveOpenGraphImage(MediaUrlService, imageSource);
        if (!string.IsNullOrWhiteSpace(resolved))
        {
            return resolved;
        }

        var fallback = SeoImageMetadata.ResolveOpenGraphImage(MediaUrlService, DefaultOgImagePath);
        return !string.IsNullOrWhiteSpace(fallback)
            ? fallback
            : MetadataService.BuildAbsoluteUrl(DefaultOgImagePath);
    }

    private static string BuildFallbackProductTitle(string slug)
    {
        if (string.IsNullOrWhiteSpace(slug))
        {
            return "Product - Buy Online";
        }

        var humanized = string.Join(
            ' ',
            slug.Split('-', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(segment => segment.Length > 0)
                .Select(segment => char.ToUpperInvariant(segment[0]) + segment[1..].ToLowerInvariant()));

        return string.IsNullOrWhiteSpace(humanized)
            ? "Product - Buy Online"
            : $"{humanized} - Buy Online";
    }

    private void InitializeSelectionState(StoreProduct currentProduct)
    {
        selectedVariant = currentProduct.Variants
            .OrderByDescending(variant => variant.Id == currentProduct.DefaultVariantId)
            .ThenBy(variant => variant.Position)
            .FirstOrDefault(variant => variant.IsActive)
            ?? currentProduct.Variants.OrderBy(variant => variant.Position).FirstOrDefault();

        selectedOptions = selectedVariant?.SelectedOptions.ToDictionary(option => option.OptionName, option => option.Value)
            ?? new Dictionary<string, string>();

        optionValueLookup = currentProduct.Variants
            .SelectMany(variant => variant.SelectedOptions)
            .GroupBy(option => option.OptionName, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(
                group => group.Key,
                group => (IReadOnlyCollection<string>)group
                    .Select(item => item.Value)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .OrderBy(item => item, StringComparer.OrdinalIgnoreCase)
                    .ToArray(),
                StringComparer.OrdinalIgnoreCase);

        optionNames = optionValueLookup.Keys.OrderBy(value => value, StringComparer.OrdinalIgnoreCase).ToArray();
        groupedAttributes = currentProduct.Attributes
            .GroupBy(attribute => string.IsNullOrWhiteSpace(attribute.GroupName) ? "General" : attribute.GroupName!, StringComparer.OrdinalIgnoreCase)
            .OrderBy(group => group.Key, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(
                group => group.Key,
                group => (IReadOnlyCollection<StoreProductAttribute>)group.OrderBy(item => item.Position).ToArray(),
                StringComparer.OrdinalIgnoreCase);

        UpdateGallery(currentProduct);
        selectionMessage = null;
    }

    private void SelectOption(string optionName, string? value)
    {
        if (product is null || string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        var nextSelection = new Dictionary<string, string>(selectedOptions, StringComparer.OrdinalIgnoreCase)
        {
            [optionName] = value,
        };

        var match = product.Variants
            .Where(variant => variant.IsActive)
            .FirstOrDefault(variant => VariantMatchesSelection(variant, nextSelection));

        if (match is null)
        {
            selectionMessage = "This variant combination is not available.";
            return;
        }

        selectedOptions = nextSelection;
        selectedVariant = match;
        selectionMessage = null;
        UpdateGallery(product);
    }

    private string GetSelectedOptionValue(string optionName)
    {
        return selectedOptions.TryGetValue(optionName, out var value)
            ? value
            : GetOptionValues(optionName).FirstOrDefault() ?? string.Empty;
    }

    private IReadOnlyCollection<string> GetOptionValues(string optionName)
    {
        return optionValueLookup.TryGetValue(optionName, out var values) ? values : [];
    }

    private void UpdateGallery(StoreProduct currentProduct)
    {
        galleryImages = currentProduct.Images
            .Where(image => image.VariantId is null || image.VariantId == selectedVariant?.Id)
            .OrderByDescending(image => image.VariantId == selectedVariant?.Id && image.IsPrimary)
            .ThenByDescending(image => image.IsPrimary)
            .ThenBy(image => image.Position)
            .ToArray();

        selectedImageUrl = selectedVariant?.ImageUrl
            ?? galleryImages.FirstOrDefault()?.SourceUrl
            ?? currentProduct.ImageUrl;
        selectedImageAlt = galleryImages.FirstOrDefault(image => image.SourceUrl == selectedImageUrl)?.AltText ?? currentProduct.Name;
    }

    private void SelectImage(string? sourceUrl, string? altText)
    {
        if (string.IsNullOrWhiteSpace(sourceUrl))
        {
            return;
        }

        selectedImageUrl = sourceUrl;
        selectedImageAlt = altText ?? product?.Name;
    }

    private static bool VariantMatchesSelection(StoreProductVariant variant, IReadOnlyDictionary<string, string> selection)
    {
        foreach (var pair in selection)
        {
            var selectedOption = variant.SelectedOptions.FirstOrDefault(option =>
                string.Equals(option.OptionName, pair.Key, StringComparison.OrdinalIgnoreCase));
            if (selectedOption is null ||
                !string.Equals(selectedOption.Value, pair.Value, StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }
        }

        return true;
    }

    private async Task LoadReviewStateAsync(Guid productId)
    {
        reviewSummary = await StoreApiClient.GetProductReviewSummaryAsync(productId, CancellationToken.None);
        await LoadReviewsAsync();
    }

    private async Task LoadQuestionStateAsync(Guid productId)
    {
        isQuestionsLoading = true;
        questionPage = await StoreApiClient.GetProductQuestionsAsync(productId, questionPage.Page, questionPage.PageSize, CancellationToken.None);
        isQuestionsLoading = false;
    }

    private async Task LoadReviewsAsync()
    {
        if (product is null)
        {
            return;
        }

        isReviewsLoading = true;
        int? ratingFilter = int.TryParse(reviewRatingFilter, out var parsedRating) ? parsedRating : null;
        reviewPage = await StoreApiClient.GetProductReviewsAsync(
            product.Id,
            reviewPage.Page <= 0 ? 1 : reviewPage.Page,
            reviewPage.PageSize <= 0 ? 10 : reviewPage.PageSize,
            reviewSort,
            ratingFilter,
            CancellationToken.None);
        isReviewsLoading = false;
    }

    private async Task PreviousReviewPageAsync()
    {
        if (reviewPage.Page <= 1)
        {
            return;
        }

        reviewPage = reviewPage with { Page = reviewPage.Page - 1 };
        await LoadReviewsAsync();
    }

    private async Task NextReviewPageAsync()
    {
        if (reviewPage.Page >= reviewPage.TotalPages)
        {
            return;
        }

        reviewPage = reviewPage with { Page = reviewPage.Page + 1 };
        await LoadReviewsAsync();
    }

    private async Task PreviousQuestionPageAsync()
    {
        if (product is null || questionPage.Page <= 1)
        {
            return;
        }

        questionPage = questionPage with { Page = questionPage.Page - 1 };
        await LoadQuestionStateAsync(product.Id);
    }

    private async Task NextQuestionPageAsync()
    {
        if (product is null || questionPage.Page >= questionPage.TotalPages)
        {
            return;
        }

        questionPage = questionPage with { Page = questionPage.Page + 1 };
        await LoadQuestionStateAsync(product.Id);
    }

    private async Task SubmitReviewAsync()
    {
        if (product is null)
        {
            return;
        }

        isSubmittingReview = true;
        reviewMessage = null;

        var reviewId = await StoreApiClient.SubmitReviewAsync(
            product.Id,
            new StoreSubmitReviewRequest(reviewForm.VariantId, reviewForm.Title, reviewForm.Body, reviewForm.Rating),
            CancellationToken.None);

        reviewMessage = reviewId is null
            ? "Unable to submit review."
            : "Review submitted for moderation.";

        if (reviewId is not null)
        {
            reviewForm = new ReviewFormModel { Rating = 5, VariantId = selectedVariant?.Id ?? product.DefaultVariantId };
            await LoadReviewsAsync();
        }

        isSubmittingReview = false;
    }

    private async Task VoteReviewAsync(Guid reviewId, string voteType)
    {
        var result = await StoreApiClient.VoteReviewAsync(reviewId, voteType, CancellationToken.None);
        if (result is null)
        {
            reviewMessage = "Unable to submit vote.";
            return;
        }

        reviewPage = reviewPage with
        {
            Items = reviewPage.Items.Select(review => review.Id == reviewId
                ? review with
                {
                    HelpfulCount = result.HelpfulCount,
                    NotHelpfulCount = result.NotHelpfulCount,
                }
                : review).ToArray(),
        };
    }

    private async Task ReportReviewAsync(Guid reviewId)
    {
        var reportId = await StoreApiClient.ReportReviewAsync(reviewId, "Other", null, CancellationToken.None);
        reviewMessage = reportId is null
            ? "Unable to report review."
            : "Review reported for moderation.";
    }

    private async Task SubmitQuestionAsync()
    {
        if (product is null)
        {
            return;
        }

        isSubmittingQuestion = true;
        questionMessage = null;

        var questionId = await StoreApiClient.SubmitQuestionAsync(
            product.Id,
            new StoreSubmitQuestionRequest(questionForm.QuestionText ?? string.Empty),
            CancellationToken.None);

        questionMessage = questionId is null
            ? "Unable to submit question."
            : "Question submitted for moderation.";

        if (questionId is not null)
        {
            questionForm = new QuestionFormModel();
            await LoadQuestionStateAsync(product.Id);
        }

        isSubmittingQuestion = false;
    }

    private async Task SubmitAnswerAsync(Guid questionId)
    {
        if (string.IsNullOrWhiteSpace(GetPendingAnswer(questionId)))
        {
            questionMessage = "Answer is too short.";
            return;
        }

        var answerId = await StoreApiClient.SubmitAnswerAsync(
            questionId,
            new StoreSubmitAnswerRequest(GetPendingAnswer(questionId)),
            CancellationToken.None);

        questionMessage = answerId is null
            ? "Unable to submit answer."
            : "Answer submitted for moderation.";

        if (product is not null && answerId is not null)
        {
            pendingAnswers.Remove(questionId);
            await LoadQuestionStateAsync(product.Id);
        }
    }

    private string GetPendingAnswer(Guid questionId)
    {
        return pendingAnswers.TryGetValue(questionId, out var value) ? value : string.Empty;
    }

    private void SetPendingAnswer(Guid questionId, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            pendingAnswers.Remove(questionId);
            return;
        }

        pendingAnswers[questionId] = value;
    }

    private void InitializeForms(StoreProduct currentProduct)
    {
        reviewForm = new ReviewFormModel
        {
            Rating = 5,
            VariantId = selectedVariant?.Id ?? currentProduct.DefaultVariantId,
        };
        questionForm = new QuestionFormModel();
    }

    private static string GetVariantLabel(StoreProductVariant variant)
    {
        if (!string.IsNullOrWhiteSpace(variant.Name))
        {
            return variant.Name;
        }

        var optionSummary = string.Join(", ", variant.SelectedOptions.Select(option => $"{option.OptionName}: {option.Value}"));
        return string.IsNullOrWhiteSpace(optionSummary) ? variant.Sku : optionSummary;
    }

    private sealed class ReviewFormModel
    {
        public Guid? VariantId { get; set; }

        public string? Title { get; set; }

        public string? Body { get; set; }

        public int Rating { get; set; } = 5;
    }

    private sealed class QuestionFormModel
    {
        public string? QuestionText { get; set; }
    }
}

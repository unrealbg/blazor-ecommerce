@page "/"
@using Microsoft.Extensions.Options
@using Storefront.Web.Services.Api
@using Storefront.Web.Services.Media
@using Storefront.Web.Services.Seo
@inject IStoreApiClient StoreApiClient
@inject ILogger<Home> Logger
@inject IPageMetadataService MetadataService
@inject IStructuredDataService StructuredDataService
@inject IOptions<SiteOptions> SiteOptions

<SeoHead Metadata="metadata" JsonLdScripts="jsonLdScripts" />

<div class="commerce-page storefront-home">
    <section class="home-hero">
        <div class="home-hero-copy">
            <p class="eyebrow">Tech essentials</p>
            <h1>Find the gear you need, fast.</h1>
            <p class="body-copy">Shop audio, workspace, and everyday accessories with live stock and EUR pricing.</p>
            <div class="button-row">
                <a class="button button-primary" href="/category/all-products">Shop all products</a>
                <a class="button button-secondary" href="#featured-products">View featured products</a>
            </div>
            <nav class="hero-quick-links" aria-label="Popular categories">
                <a href="/category/audio">Audio</a>
                <a href="/category/workspace">Workspace</a>
                <a href="/category/accessories">Accessories</a>
            </nav>
        </div>

        <article class="home-feature-card" aria-label="Featured product">
            <div class="home-feature-media @(HasHeroImage ? null : "home-feature-media-placeholder")">
                <a href="@HeroHref">
                    @if (HasHeroImage)
                    {
                        <ResponsiveImage
                            Source="@heroProduct!.ImageUrl"
                            Alt="@heroProduct.Name"
                            Preset="MediaImagePreset.ProductHero"
                            CssClass="home-feature-image"
                            Priority="true"
                            HideOnError="true" />
                    }
                    else
                    {
                        <div class="home-feature-placeholder" aria-hidden="true">
                            <span class="home-feature-placeholder-mark"></span>
                        </div>
                    }
                </a>
            </div>
            <div class="home-feature-copy">
                <p class="eyebrow">Featured pick</p>
                <h2>@(heroProduct?.Name ?? "Browse the catalog")</h2>
                <p>@(heroProduct is null ? "Products are loading from the catalog." : ResolveHeroDescription(heroProduct))</p>
                @if (heroProduct is not null)
                {
                    <div class="price-row">
                        <span class="price-current">@FormatPrice(heroProduct.Amount, heroProduct.Currency)</span>
                        @if (heroProduct.CompareAtAmount is > 0m && heroProduct.CompareAtAmount > heroProduct.Amount)
                        {
                            <span class="price-compare">@FormatPrice(heroProduct.CompareAtAmount.Value, heroProduct.Currency)</span>
                        }
                    </div>
                    <p class="inline-meta">@GetHeroAvailabilityLabel(heroProduct)</p>
                }
                <a class="inline-link" href="@HeroHref">View details</a>
            </div>
        </article>
    </section>

    <section class="storefront-section" id="featured-products">
        <div class="section-header">
            <div>
                <p class="eyebrow">Featured</p>
                <h2>Products worth comparing</h2>
            </div>
            <a class="inline-link" href="/search?sort=popular">Browse best sellers</a>
        </div>

        @if (isLoading)
        {
            <p class="empty-state store-empty-state">Loading products...</p>
        }
        else if (!string.IsNullOrWhiteSpace(loadErrorMessage))
        {
            <p class="empty-state store-empty-state">@loadErrorMessage</p>
        }
        else if (signatureProducts.Count == 0)
        {
            <p class="empty-state store-empty-state">No products available yet.</p>
        }
        else
        {
            <div class="product-grid home-product-grid">
                @foreach (var product in signatureProducts)
                {
                    <ProductCard
                        Product="product"
                        Badge="@(product.CompareAtAmount.HasValue && product.CompareAtAmount.Value > product.Amount ? "Sale" : product.IsFeatured ? "Featured" : null)" />
                }
            </div>
        }
    </section>

    <section class="storefront-section" id="featured-categories">
        <div class="section-header">
            <div>
                <p class="eyebrow">Categories</p>
                <h2>Shop by category</h2>
            </div>
            <a class="inline-link" href="/search">View all</a>
        </div>

        <div class="category-grid">
            @foreach (var category in featuredCategories)
            {
                <CategoryCard
                    Name="@category.Name"
                    Eyebrow="@category.Eyebrow"
                    Description="@category.Description"
                    ImageUrl="@category.ImageUrl"
                    Href="@category.Href"
                    CtaLabel="@category.CtaLabel" />
            }
        </div>
    </section>

    <section class="service-strip" aria-label="Shopping information">
        <article>
            <strong>EU delivery</strong>
            <span>Tracked shipping with clear order updates.</span>
        </article>
        <article>
            <strong>30-day returns</strong>
            <span>Simple return guidance after purchase.</span>
        </article>
        <article>
            <strong>Secure checkout</strong>
            <span>Cart totals and payment steps stay visible.</span>
        </article>
    </section>
</div>

@code {
    private PageMetadata metadata = new("Storefront Home", "Discover featured products and shop online in EUR.", "/");
    private const int FeaturedProductsLoadMaxAttempts = 3;
    private readonly List<StoreProduct> featuredProducts = [];
    private IReadOnlyCollection<string> jsonLdScripts = [];
    private bool isLoading = true;
    private string? loadErrorMessage;
    private StoreProduct? heroProduct;
    private IReadOnlyList<StoreProduct> signatureProducts = [];
    private readonly IReadOnlyCollection<HomeCategory> featuredCategories =
    [
        new("Audio", "Headphones, speakers, and listening gear.", "/category/audio", null, "Listening", "Shop audio"),
        new("Workspace", "Keyboards, docks, displays, and desk tools.", "/category/workspace", null, "Desk setup", "Shop workspace"),
        new("Accessories", "Power, carry, and finishing pieces.", "/category/accessories", null, "Everyday", "Shop accessories"),
    ];

    private string HeroHref => heroProduct is null ? "/category/all-products" : $"/product/{heroProduct.Slug}";

    private bool HasHeroImage => !string.IsNullOrWhiteSpace(heroProduct?.ImageUrl);

    protected override void OnInitialized()
    {
        metadata = MetadataService.ForHome();
        jsonLdScripts =
        [
            StructuredDataService.BuildWebSiteSearchJsonLd(SiteOptions.Value.BaseUrl),
        ];
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadFeaturedProductsAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadFeaturedProductsAsync()
    {
        Exception? lastException = null;

        for (var attempt = 1; attempt <= FeaturedProductsLoadMaxAttempts; attempt++)
        {
            try
            {
                var products = await StoreApiClient.GetProductsAsync(CancellationToken.None);
                featuredProducts.Clear();
                featuredProducts.AddRange(
                    products
                        .Where(product => product.IsActive)
                        .Where(product => string.Equals(product.Currency, "EUR", StringComparison.Ordinal))
                        .OrderByDescending(product => product.IsFeatured)
                        .ThenByDescending(product => product.CompareAtAmount.HasValue)
                        .ThenBy(product => product.Name)
                        .Take(8));

                heroProduct = featuredProducts.FirstOrDefault();
                signatureProducts = featuredProducts.Take(4).ToArray();
                loadErrorMessage = null;
                return;
            }
            catch (Exception exception) when (IsTransientProductLoadFailure(exception))
            {
                lastException = exception;
                Logger.LogWarning(
                    exception,
                    "Failed to load featured products for the home page on attempt {Attempt} of {MaxAttempts}.",
                    attempt,
                    FeaturedProductsLoadMaxAttempts);

                if (attempt == FeaturedProductsLoadMaxAttempts)
                {
                    break;
                }

                await Task.Delay(TimeSpan.FromMilliseconds(500 * attempt));
            }
        }

        heroProduct = null;
        signatureProducts = [];

        Logger.LogWarning(
            lastException,
            "Rendering the home page without featured products because the catalog API is temporarily unavailable.");

        loadErrorMessage = "Products are temporarily unavailable. Please refresh in a moment.";
    }

    private static bool IsTransientProductLoadFailure(Exception exception)
    {
        return exception is HttpRequestException or TaskCanceledException or TimeoutException;
    }

    private static string ResolveHeroDescription(StoreProduct product)
    {
        return !string.IsNullOrWhiteSpace(product.ShortDescription)
            ? product.ShortDescription
            : !string.IsNullOrWhiteSpace(product.Description)
                ? product.Description
                : "A useful everyday product with clear pricing and availability.";
    }

    private static string GetHeroAvailabilityLabel(StoreProduct? product)
    {
        if (product is null)
        {
            return "Ready to ship";
        }

        return product.IsInStock
            ? product.AvailableQuantity is > 0
                ? $"{product.AvailableQuantity.Value} ready now"
                : "In stock"
            : product.AllowBackorder
                ? "Backorder available"
                : "Currently unavailable";
    }

    private static string FormatPrice(decimal amount, string currency)
    {
        return $"{amount:0.00} {currency}";
    }

    private sealed record HomeCategory(string Name, string Description, string Href, string? ImageUrl, string Eyebrow, string CtaLabel);
}

@page "/checkout/payment"
@rendermode InteractiveServer
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient
@inject NavigationManager Navigation

<PageTitle>Checkout Payment</PageTitle>

<div class="tech-checkout-page tech-flow-page">
    <section class="tech-page-intro">
        <p class="tech-eyebrow">Payment</p>
        <h1>Confirm payment for your order.</h1>
        <p>Secure confirmation for premium hardware orders, with clear provider status and next steps.</p>
    </section>

    <CheckoutProgressHeader CurrentStep="3" Steps="checkoutSteps" />

    @if (OrderId is null)
    {
        <section class="tech-empty-panel">
            <p class="tech-eyebrow">Missing order</p>
            <h2>We need an order reference before payment can begin.</h2>
            <p>Return to checkout and create the order first.</p>
            <a class="tech-button tech-button-primary" href="/checkout">Return to checkout</a>
        </section>
    }
    else
    {
        <section class="tech-detail-card tech-flow-card">
            <div class="tech-detail-card-header">
                <p class="tech-eyebrow">Payment intent</p>
                <h2>Order @OrderId</h2>
            </div>

            <p class="tech-inline-meta">The payment step stays explicit and calm so the final confirmation feels trustworthy.</p>

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <p class="status-message">@message</p>
            }

            <div class="tech-summary-list">
                <div class="tech-summary-row">
                    <span>Order reference</span>
                    <strong>@OrderId</strong>
                </div>
                @if (paymentIntent is not null)
                {
                    <div class="tech-summary-row">
                        <span>Provider</span>
                        <strong>@paymentIntent.Provider</strong>
                    </div>
                    <div class="tech-summary-row">
                        <span>Status</span>
                        <strong>@paymentIntent.Status</strong>
                    </div>
                }
            </div>

            @if (paymentIntent?.RequiresAction is true)
            {
                <p class="status-message warning">Additional customer action is required before payment can complete.</p>
            }

            <div class="tech-flow-actions">
                @if (paymentIntent is null)
                {
                    <button class="tech-button tech-button-primary" @onclick="StartPaymentAsync" disabled="@isLoading">Start payment</button>
                    <a class="tech-button tech-button-ghost" href="/checkout">Back to checkout</a>
                }
                else if (RequiresConfirmation(paymentIntent.Status))
                {
                    <button class="tech-button tech-button-primary" @onclick="ConfirmPaymentAsync" disabled="@isLoading">Confirm payment</button>
                    <button class="tech-button tech-button-ghost" @onclick="CancelPaymentAsync" disabled="@isLoading">Cancel payment</button>
                }
                else
                {
                    <a class="tech-button tech-button-ghost" href="/checkout">Back to checkout</a>
                }
            </div>
        </section>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    public Guid? OrderId { get; set; }

    private readonly IReadOnlyList<string> checkoutSteps = ["Bag", "Shipping", "Payment", "Review"];
    private StorePaymentIntentAction? paymentIntent;
    private bool isLoading;
    private string? message;

    private async Task StartPaymentAsync()
    {
        if (OrderId is null)
        {
            message = "Order id is required.";
            return;
        }

        isLoading = true;
        message = null;

        var idempotencyKey = Guid.NewGuid().ToString("N");
        var result = await StoreApiClient.CreatePaymentIntentAsync(
            OrderId.Value,
            "Demo",
            idempotencyKey,
            customerEmail: null,
            CancellationToken.None);

        isLoading = false;

        if (result is null)
        {
            message = "Payment intent could not be created.";
            return;
        }

        paymentIntent = result;
        await HandlePaymentResultAsync(result);
    }

    private async Task ConfirmPaymentAsync()
    {
        if (paymentIntent is null)
        {
            return;
        }

        isLoading = true;
        message = null;

        var idempotencyKey = Guid.NewGuid().ToString("N");
        var result = await StoreApiClient.ConfirmPaymentIntentAsync(
            paymentIntent.PaymentIntentId,
            idempotencyKey,
            CancellationToken.None);

        isLoading = false;

        if (result is null)
        {
            message = "Payment confirmation failed.";
            return;
        }

        paymentIntent = result;
        await HandlePaymentResultAsync(result);
    }

    private async Task CancelPaymentAsync()
    {
        if (paymentIntent is null)
        {
            return;
        }

        isLoading = true;
        message = null;

        var result = await StoreApiClient.CancelPaymentIntentAsync(
            paymentIntent.PaymentIntentId,
            "Cancelled by customer",
            CancellationToken.None);

        isLoading = false;

        if (result is null)
        {
            message = "Payment cancellation failed.";
            return;
        }

        paymentIntent = result;
        await HandlePaymentResultAsync(result);
    }

    private Task HandlePaymentResultAsync(StorePaymentIntentAction result)
    {
        if (OrderId is null)
        {
            return Task.CompletedTask;
        }

        if (result.Status.Equals("Captured", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo($"/checkout/success?orderId={OrderId:D}&paymentIntentId={result.PaymentIntentId:D}");
            return Task.CompletedTask;
        }

        if (result.Status.Equals("Failed", StringComparison.OrdinalIgnoreCase) ||
            result.Status.Equals("Cancelled", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo($"/checkout/failure?orderId={OrderId:D}&paymentIntentId={result.PaymentIntentId:D}");
            return Task.CompletedTask;
        }

        message = result.RequiresAction
            ? "Provider requires additional action. Confirm payment after action completes."
            : "Payment intent is ready for confirmation.";

        return Task.CompletedTask;
    }

    private static bool RequiresConfirmation(string status)
    {
        return status.Equals("Created", StringComparison.OrdinalIgnoreCase) ||
               status.Equals("Pending", StringComparison.OrdinalIgnoreCase) ||
               status.Equals("RequiresAction", StringComparison.OrdinalIgnoreCase) ||
               status.Equals("Authorized", StringComparison.OrdinalIgnoreCase);
    }
}

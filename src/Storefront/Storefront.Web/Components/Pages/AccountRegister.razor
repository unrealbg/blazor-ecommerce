@page "/account/register"
@inject NavigationManager NavigationManager
@inject Storefront.Web.Services.Api.IStoreApiClient StoreApiClient

<PageTitle>Account Register</PageTitle>

<div class="account-auth-shell">
    <section class="tech-panel account-auth-card">
        <p class="tech-eyebrow">Create account</p>
        <h1>Create a private client account for faster checkout, delivery updates, and ongoing support.</h1>
        <p class="tech-copy">Save your details once and keep future purchases, addresses, and account history inside the same premium storefront environment.</p>

        <EditForm Model="model" OnValidSubmit="SubmitAsync">
            <div class="form-grid tech-form-grid">
                <label class="tech-field tech-field-full">
                    <span>Email</span>
                    <InputText @bind-Value="model.Email" />
                </label>
                <label class="tech-field">
                    <span>Password</span>
                    <InputText @bind-Value="model.Password" Type="password" />
                </label>
                <label class="tech-field">
                    <span>Phone</span>
                    <InputText @bind-Value="model.PhoneNumber" />
                </label>
                <label class="tech-field">
                    <span>First name</span>
                    <InputText @bind-Value="model.FirstName" />
                </label>
                <label class="tech-field">
                    <span>Last name</span>
                    <InputText @bind-Value="model.LastName" />
                </label>
            </div>
            <div class="account-inline-actions">
                <button class="tech-button tech-button-primary" type="submit" disabled="@isSubmitting">Create account</button>
                <a class="tech-inline-link" href="/account/login">Already registered? Sign in →</a>
            </div>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="status-message">@message</p>
        }
    </section>
</div>

@code {
    private readonly RegisterModel model = new();
    private bool isSubmitting;
    private string? message;

    private async Task SubmitAsync()
    {
        isSubmitting = true;
        message = null;

        var registerResponse = await StoreApiClient.RegisterAsync(
            model.Email,
            model.Password,
            model.FirstName,
            model.LastName,
            model.PhoneNumber,
            CancellationToken.None);

        if (registerResponse is null)
        {
            message = "Unable to register account.";
            isSubmitting = false;
            return;
        }

        var loginResponse = await StoreApiClient.LoginAsync(
            model.Email,
            model.Password,
            rememberMe: true,
            CancellationToken.None);

        if (loginResponse is null)
        {
            message = "Account created. Please sign in.";
            NavigationManager.NavigateTo("/account/login", forceLoad: true);
            return;
        }

        NavigationManager.NavigateTo("/account/profile", forceLoad: true);
    }

    private sealed class RegisterModel
    {
        public string Email { get; set; } = string.Empty;

        public string Password { get; set; } = string.Empty;

        public string? FirstName { get; set; }

        public string? LastName { get; set; }

        public string? PhoneNumber { get; set; }
    }
}

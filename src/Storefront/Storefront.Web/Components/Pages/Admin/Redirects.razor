@page "/admin/redirects"
@layout Storefront.Web.Components.Layout.AdminLayout
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient

<PageTitle>Redirects</PageTitle>

<h1>Redirect Rules</h1>
<p>Manage manual SEO redirects and deactivate outdated rules.</p>

<section class="admin-panel">
    <h2>Create Redirect</h2>
    <form class="form-grid" @onsubmit="CreateAsync" @onsubmit:preventDefault="true">
        <label>
            From path
            <input @bind="createModel.FromPath" placeholder="/blog/old-slug" required />
        </label>

        <label>
            To path
            <input @bind="createModel.ToPath" placeholder="/blog/new-slug" required />
        </label>

        <label>
            Status code
            <input type="number" @bind="createModel.StatusCode" min="301" max="308" step="1" required />
        </label>

        <button class="btn-primary" type="submit" disabled="@isSubmitting">Create Rule</button>
    </form>

    @if (!string.IsNullOrWhiteSpace(feedbackMessage))
    {
        <p class="status-message">@feedbackMessage</p>
    }
</section>

<section class="admin-panel">
    <h2>Existing Redirects</h2>

    @if (isLoading)
    {
        <p>Loading redirect rules...</p>
    }
    else if (rules.Count == 0)
    {
        <p>No redirect rules created yet.</p>
    }
    else
    {
        <table class="cart-table">
            <thead>
                <tr>
                    <th>From</th>
                    <th>To</th>
                    <th>Status</th>
                    <th>Hits</th>
                    <th>Updated</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rule in rules)
                {
                    <tr>
                        <td>@rule.FromPath</td>
                        <td>@rule.ToPath</td>
                        <td>@rule.StatusCode</td>
                        <td>@rule.HitCount</td>
                        <td>@rule.UpdatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (rule.IsActive)
                            {
                                <button class="btn-link danger" @onclick="() => DeactivateAsync(rule.Id)">Deactivate</button>
                            }
                            else
                            {
                                <span>Inactive</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="pagination">
            <button class="page-link" @onclick="PreviousPageAsync" disabled="@(currentPage <= 1)">Previous</button>
            <span class="page-indicator">Page @currentPage</span>
            <button class="page-link" @onclick="NextPageAsync" disabled="@(rules.Count < currentPageSize)">Next</button>
        </div>
    }
</section>

@code {
    private const int DefaultStatusCode = 301;
    private readonly List<StoreRedirectRule> rules = [];
    private CreateRedirectModel createModel = new();
    private bool isLoading = true;
    private bool isSubmitting;
    private string? feedbackMessage;
    private int currentPage = 1;
    private int currentPageSize = 20;

    protected override async Task OnInitializedAsync()
    {
        await LoadRulesAsync();
    }

    private async Task LoadRulesAsync()
    {
        isLoading = true;
        StateHasChanged();

        var response = await StoreApiClient.GetRedirectRulesAsync(currentPage, currentPageSize, CancellationToken.None);

        rules.Clear();
        rules.AddRange(response.Items);

        currentPage = response.Page;
        currentPageSize = response.PageSize;
        isLoading = false;
    }

    private async Task CreateAsync()
    {
        if (isSubmitting)
        {
            return;
        }

        isSubmitting = true;
        feedbackMessage = null;

        var redirectRuleId = await StoreApiClient.CreateRedirectRuleAsync(
            createModel.FromPath,
            createModel.ToPath,
            createModel.StatusCode,
            CancellationToken.None);

        if (redirectRuleId is null)
        {
            feedbackMessage = "Could not create redirect rule.";
            isSubmitting = false;
            return;
        }

        feedbackMessage = $"Redirect rule created: {redirectRuleId}";
        createModel = new CreateRedirectModel();
        await LoadRulesAsync();
        isSubmitting = false;
    }

    private async Task DeactivateAsync(Guid redirectRuleId)
    {
        feedbackMessage = null;

        var success = await StoreApiClient.DeactivateRedirectRuleAsync(redirectRuleId, CancellationToken.None);
        feedbackMessage = success
            ? "Redirect rule deactivated."
            : "Could not deactivate redirect rule.";

        await LoadRulesAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (currentPage <= 1)
        {
            return;
        }

        currentPage--;
        await LoadRulesAsync();
    }

    private async Task NextPageAsync()
    {
        if (rules.Count < currentPageSize)
        {
            return;
        }

        currentPage++;
        await LoadRulesAsync();
    }

    private sealed class CreateRedirectModel
    {
        public string FromPath { get; set; } = string.Empty;

        public string ToPath { get; set; } = string.Empty;

        public int StatusCode { get; set; } = DefaultStatusCode;
    }
}

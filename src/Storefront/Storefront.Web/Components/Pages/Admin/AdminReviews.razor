@page "/admin/reviews"
@page "/admin/reviews/pending"
@rendermode InteractiveServer
@layout Storefront.Web.Components.Layout.AdminLayout
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient
@inject NavigationManager NavigationManager

<PageTitle>Admin Reviews</PageTitle>

<h1>Review Moderation</h1>

<div class="inventory-panel">
    <label>
        Status
        <select @bind="statusFilter">
            <option value="">All</option>
            <option value="Pending">Pending</option>
            <option value="Approved">Approved</option>
            <option value="Rejected">Rejected</option>
            <option value="Hidden">Hidden</option>
        </select>
    </label>
    <button class="btn-primary" type="button" @onclick="LoadAsync">Apply</button>
    <a class="btn-secondary" href="/admin/reviews/reports">Open reports</a>
</div>

@if (isLoading)
{
    <p>Loading reviews...</p>
}
else if (page.Items.Count == 0)
{
    <p>No reviews found.</p>
}
else
{
    <div class="order-list">
        @foreach (var review in page.Items)
        {
            <article class="order-card">
                <header>
                    <div>
                        <strong><a href="/product/@review.ProductSlug">@review.ProductName</a></strong>
                        @if (review.IsVerifiedPurchase)
                        {
                            <span class="status-message">Verified purchase</span>
                        }
                    </div>
                    <p>@review.CreatedAtUtc.ToString("yyyy-MM-dd")</p>
                </header>
                <p>Status: <strong>@review.Status</strong></p>
                <p>Reviewer: @review.DisplayName</p>
                <RatingStars Value="review.Rating" />
                @if (!string.IsNullOrWhiteSpace(review.Title))
                {
                    <h3>@review.Title</h3>
                }
                @if (!string.IsNullOrWhiteSpace(review.Body))
                {
                    <p>@review.Body</p>
                }
                <p class="meta">Reports: @review.ReportCount</p>
                <div class="cart-actions">
                    <button class="btn-secondary" type="button" @onclick='() => ModerateAsync(review.Id, "approve")'>Approve</button>
                    <button class="btn-secondary" type="button" @onclick='() => ModerateAsync(review.Id, "reject")'>Reject</button>
                    <button class="btn-link danger" type="button" @onclick='() => ModerateAsync(review.Id, "hide")'>Hide</button>
                </div>
            </article>
        }
    </div>
}

@if (!string.IsNullOrWhiteSpace(message))
{
    <p class="status-message">@message</p>
}

@code {
    private StoreReviewModerationPage page = new(1, 20, 0, 1, []);
    private bool isLoading = true;
    private string? statusFilter;
    private string? message;

    protected override Task OnInitializedAsync()
    {
        statusFilter = NavigationManager.Uri.EndsWith("/pending", StringComparison.OrdinalIgnoreCase) ? "Pending" : null;
        return LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        page = await StoreApiClient.GetAdminReviewsAsync(statusFilter, 1, 20, CancellationToken.None);
        isLoading = false;
    }

    private async Task ModerateAsync(Guid reviewId, string action)
    {
        var success = action switch
        {
            "approve" => await StoreApiClient.ApproveReviewAsync(reviewId, null, CancellationToken.None),
            "reject" => await StoreApiClient.RejectReviewAsync(reviewId, null, CancellationToken.None),
            _ => await StoreApiClient.HideReviewAsync(reviewId, null, CancellationToken.None),
        };

        message = success ? $"Review {action}d." : $"Unable to {action} review.";
        await LoadAsync();
    }
}

@page "/cart"
@rendermode InteractiveServer
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient
@inject ILogger<Cart> Logger
@inject Storefront.Web.Services.Customer.ICustomerContext CustomerContext
@inject Storefront.Web.Services.CartState CartState

<PageTitle>Your Bag</PageTitle>

<div class="tech-cart-page">
    <section class="tech-page-intro">
        <p class="tech-eyebrow">Bag</p>
        <h1>Your selected hardware, ready for a calm checkout.</h1>
        <p>Review quantities, pricing, and access codes before moving to secure payment.</p>
    </section>

    <CheckoutProgressHeader CurrentStep="1" Steps="checkoutSteps" />

    @if (isLoading)
    {
        <section class="tech-empty-panel">
            <p class="tech-eyebrow">Loading</p>
            <h2>Loading your bag</h2>
            <p>We are syncing your latest cart state.</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(loadErrorMessage))
    {
        <section class="tech-empty-panel">
            <p class="tech-eyebrow">Bag unavailable</p>
            <h2>We could not load your bag right now.</h2>
            <p>@loadErrorMessage</p>
            <a class="tech-button tech-button-primary" href="/search">Browse the collection</a>
        </section>
    }
    else if (cart is null || cart.Lines.Count == 0)
    {
        <section class="tech-empty-panel">
            <p class="tech-eyebrow">Empty bag</p>
            <h2>Your bag is currently empty.</h2>
            <p>Add a product from the collection to continue to checkout.</p>
            <a class="tech-button tech-button-primary" href="/search">Browse hardware</a>
        </section>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="status-message">@message</p>
        }

        @if (cart.Messages.Count > 0)
        {
            foreach (var cartMessage in cart.Messages)
            {
                <p class="status-message warning">@cartMessage</p>
            }
        }

        <div class="tech-cart-layout">
            <div class="tech-cart-main">
                <section class="tech-detail-card tech-cart-coupon">
                    <div class="tech-detail-card-header">
                        <p class="tech-eyebrow">Promotion</p>
                        <h2>Apply a private access or loyalty code</h2>
                    </div>

                    <p class="tech-inline-meta">Promotions stay secondary so the order summary remains clear and easy to scan.</p>

                    <div class="form-grid tech-form-grid">
                        <label class="tech-field">
                            <span>Coupon code</span>
                            <input @bind="couponCode" placeholder="SAVE10" />
                        </label>
                    </div>

                    <div class="cart-actions">
                        <button type="button" class="btn-primary" @onclick="ApplyCouponAsync">Apply coupon</button>
                        @if (!string.IsNullOrWhiteSpace(cart.AppliedCouponCode))
                        {
                            <button type="button" class="btn-link danger" @onclick="RemoveCouponAsync">Remove coupon</button>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(cart.AppliedCouponCode))
                    {
                        <p class="status-message">Applied coupon: <strong>@cart.AppliedCouponCode</strong></p>
                    }
                </section>

                <section class="tech-detail-card tech-cart-lines">
                    <div class="tech-section-header">
                        <div>
                            <p class="tech-eyebrow">Selected products</p>
                            <h2>@cart.Lines.Count item@(cart.Lines.Count == 1 ? string.Empty : "s") ready for checkout.</h2>
                        </div>
                    </div>

                    <div class="tech-cart-lines-grid">
                        @foreach (var line in cart.Lines)
                        {
                            <article class="tech-cart-line">
                                <div class="tech-cart-line-media">
                                    @if (!string.IsNullOrWhiteSpace(line.ImageUrl))
                                    {
                                        <img src="@line.ImageUrl" alt="@line.ProductName" loading="lazy" decoding="async" />
                                    }
                                </div>

                                <div class="tech-cart-line-copy">
                                    <p class="tech-eyebrow">@(string.IsNullOrWhiteSpace(line.VariantName) ? "Configured product" : line.VariantName)</p>
                                    <h3>@line.ProductName</h3>
                                    @if (!string.IsNullOrWhiteSpace(line.SelectedOptionsJson))
                                    {
                                        <p class="tech-inline-meta">@line.SelectedOptionsJson</p>
                                    }

                                    <div class="tech-price-row">
                                        <span class="tech-price-current">@FormatPrice(line.FinalUnitAmount, line.Currency)</span>
                                        @if (line.CompareAtUnitAmount is > 0m && line.CompareAtUnitAmount > line.FinalUnitAmount)
                                        {
                                            <span class="tech-price-compare">@FormatPrice(line.CompareAtUnitAmount.Value, line.Currency)</span>
                                        }
                                    </div>
                                </div>

                                <div class="tech-cart-line-controls">
                                    <label class="tech-field">
                                        <span>Quantity</span>
                                        <input
                                            type="number"
                                            min="1"
                                            value="@GetQuantityValue(line.VariantId)"
                                            @onchange="args => UpdateLocalQuantity(line.VariantId, args.Value?.ToString())" />
                                    </label>

                                    <div class="cart-actions">
                                        <button type="button" class="btn-secondary" @onclick="() => UpdateQuantityAsync(line.VariantId)">Update</button>
                                        <button type="button" class="btn-link danger" @onclick="() => RemoveItemAsync(line.VariantId)">Remove</button>
                                    </div>
                                </div>

                                <div class="tech-cart-line-total">
                                    <strong>@FormatPrice(line.LineTotalAmount, line.Currency)</strong>
                                    @if (line.DiscountTotalAmount > 0m)
                                    {
                                        <p class="tech-inline-meta">Saved @FormatPrice(line.DiscountTotalAmount, line.Currency)</p>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                </section>
            </div>

            <aside class="tech-cart-aside">
                <section class="tech-detail-card tech-summary-card">
                    <div class="tech-detail-card-header">
                        <p class="tech-eyebrow">Summary</p>
                        <h2>Order totals</h2>
                    </div>

                    <div class="tech-summary-list">
                        <div class="tech-summary-row">
                            <span>Subtotal before discounts</span>
                            <strong>@FormatPrice(cart.SubtotalBeforeDiscountAmount, cart.Currency)</strong>
                        </div>
                        @if (cart.LineDiscountTotalAmount > 0m)
                        {
                            <div class="tech-summary-row">
                                <span>Line discounts</span>
                                <strong>-@FormatPrice(cart.LineDiscountTotalAmount, cart.Currency)</strong>
                            </div>
                        }
                        @if (cart.CartDiscountTotalAmount > 0m)
                        {
                            <div class="tech-summary-row">
                                <span>Cart discounts</span>
                                <strong>-@FormatPrice(cart.CartDiscountTotalAmount, cart.Currency)</strong>
                            </div>
                        }
                        <div class="tech-summary-row tech-summary-row-total">
                            <span>Total</span>
                            <strong>@FormatPrice(totalAmount, cart.Currency)</strong>
                        </div>
                    </div>

                    @if (cart.AppliedDiscounts.Count > 0)
                    {
                        <ul class="tech-summary-bullets">
                            @foreach (var discount in cart.AppliedDiscounts)
                            {
                                <li>@discount.Description: -@FormatPrice(discount.Amount, discount.Currency)</li>
                            }
                        </ul>
                    }

                    <p class="tech-inline-meta tech-summary-note">Insured EU shipping, secure checkout, and order confirmation after purchase.</p>

                    <a class="tech-button tech-button-primary tech-button-block" href="/checkout">Continue to secure checkout</a>
                </section>

                <MiniCartDrawer
                    Items="BuildMiniCartItems()"
                    Subtotal="@totalAmount"
                    Currency="@cart.Currency"
                    Eyebrow="At a glance"
                    Title="Order overview"
                    PrimaryActionHref="/checkout"
                    PrimaryActionLabel="Continue to checkout"
                    ShowSecondaryAction="false" />
            </aside>
        </div>
    }
</div>

@code {
    private StoreCart? cart;
    private bool isLoading = true;
    private string? message;
    private decimal totalAmount;
    private string customerId = string.Empty;
    private Dictionary<Guid, int> quantities = [];
    private string couponCode = string.Empty;
    private string? loadErrorMessage;
    private readonly IReadOnlyList<string> checkoutSteps = ["Bag", "Shipping", "Payment", "Review"];

    protected override async Task OnInitializedAsync()
    {
        customerId = CustomerContext.GetCustomerId();
        await ReloadCartAsync();
    }

    private async Task UpdateQuantityAsync(Guid variantId)
    {
        if (!quantities.TryGetValue(variantId, out var quantity) || quantity <= 0)
        {
            message = "Quantity must be greater than zero.";
            return;
        }

        var updated = await StoreApiClient.UpdateCartItemQuantityAsync(
            customerId,
            variantId,
            quantity,
            CancellationToken.None);

        message = updated ? "Quantity updated." : "Could not update quantity. Stock may have changed.";
        await ReloadCartAsync();
    }

    private async Task RemoveItemAsync(Guid variantId)
    {
        var removed = await StoreApiClient.RemoveCartItemAsync(customerId, variantId, CancellationToken.None);
        message = removed ? "Item removed." : "Could not remove item.";
        await ReloadCartAsync();
    }

    private async Task ApplyCouponAsync()
    {
        if (string.IsNullOrWhiteSpace(couponCode))
        {
            message = "Enter a coupon code.";
            return;
        }

        var applied = await StoreApiClient.ApplyCouponAsync(customerId, couponCode, CancellationToken.None);
        message = applied ? "Coupon applied." : "Coupon could not be applied.";
        await ReloadCartAsync();
    }

    private async Task RemoveCouponAsync()
    {
        var removed = await StoreApiClient.RemoveCouponAsync(customerId, CancellationToken.None);
        message = removed ? "Coupon removed." : "Coupon could not be removed.";
        await ReloadCartAsync();
    }

    private async Task ReloadCartAsync()
    {
        isLoading = true;
        try
        {
            cart = await StoreApiClient.GetCartAsync(customerId, CancellationToken.None);
            quantities = cart?.Lines.ToDictionary(line => line.VariantId, line => line.Quantity) ?? [];
            totalAmount = cart?.GrandTotalAmount ?? 0m;
            couponCode = cart?.AppliedCouponCode ?? couponCode;
            CartState.SetItemCount(cart?.Lines.Sum(line => line.Quantity) ?? 0);
            loadErrorMessage = null;
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to load cart for customer {CustomerId}.", customerId);
            cart = null;
            quantities = [];
            totalAmount = 0m;
            loadErrorMessage = "Your latest cart state is temporarily unavailable. Please refresh in a moment.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void UpdateLocalQuantity(Guid variantId, string? rawValue)
    {
        if (!int.TryParse(rawValue, out var quantity))
        {
            return;
        }

        quantities[variantId] = quantity;
    }

    private int GetQuantityValue(Guid variantId)
    {
        return quantities.TryGetValue(variantId, out var quantity) ? quantity : 1;
    }

    private IReadOnlyCollection<MiniCartDrawer.MiniCartLine> BuildMiniCartItems()
    {
        return cart?.Lines
            .Select(line => new MiniCartDrawer.MiniCartLine(
                line.ProductName,
                line.VariantName ?? "Configured product",
                line.LineTotalAmount,
                line.Currency,
                line.ImageUrl))
            .ToArray()
            ?? [];
    }

    private static string FormatPrice(decimal amount, string currency)
    {
        return $"{amount:0.00} {currency}";
    }
}

@page "/account/login"
@inject NavigationManager NavigationManager
@inject Storefront.Web.Services.Api.IStoreApiClient StoreApiClient

<PageTitle>Account Login</PageTitle>

<div class="account-auth-shell">
    <section class="tech-panel account-auth-card">
        <p class="tech-eyebrow">Client sign in</p>
        <h1>Access orders, saved details, and support from one private account area.</h1>
        <p class="tech-copy">Sign in to keep delivery details ready, revisit previous purchases, and move through checkout with less friction.</p>
        <ul class="account-auth-benefits">
            <li>Saved addresses and contact details for faster checkout</li>
            <li>Order tracking, payment follow-up, and delivery updates in one view</li>
            <li>Reviews and product questions kept close to your purchase history</li>
        </ul>

        <EditForm Model="model" OnValidSubmit="SubmitAsync">
            <div class="form-grid tech-form-grid">
                <label class="tech-field tech-field-full">
                    <span>Email</span>
                    <InputText @bind-Value="model.Email" />
                </label>
                <label class="tech-field tech-field-full">
                    <span>Password</span>
                    <InputText @bind-Value="model.Password" Type="password" />
                </label>
                <label class="checkbox-row account-checkbox-row">
                    <InputCheckbox @bind-Value="model.RememberMe" />
                    <span>Keep me signed in on this device</span>
                </label>
            </div>
            <div class="account-inline-actions">
                <button class="tech-button tech-button-primary" type="submit" disabled="@isSubmitting">Sign in</button>
                <a class="tech-inline-link" href="/account/register">Create account →</a>
            </div>
        </EditForm>

        <p class="account-state-support">Sign-in stays inside the same storefront system used for product discovery, checkout, and order care.</p>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="status-message">@message</p>
        }
    </section>
</div>

@code {
    private readonly LoginModel model = new();
    private bool isSubmitting;
    private string? message;

    private async Task SubmitAsync()
    {
        isSubmitting = true;
        message = null;

        var response = await StoreApiClient.LoginAsync(
            model.Email,
            model.Password,
            model.RememberMe,
            CancellationToken.None);

        if (response is null)
        {
            message = "Invalid email or password.";
            isSubmitting = false;
            return;
        }

        NavigationManager.NavigateTo("/account/profile", forceLoad: true);
    }

    private sealed class LoginModel
    {
        public string Email { get; set; } = string.Empty;

        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; } = true;
    }
}

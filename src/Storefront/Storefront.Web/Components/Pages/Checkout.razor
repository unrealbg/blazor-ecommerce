@page "/checkout"
@rendermode InteractiveServer
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient
@inject Storefront.Web.Services.Customer.ICustomerContext CustomerContext
@inject Storefront.Web.Services.CartState CartState
@inject NavigationManager Navigation

<PageTitle>Checkout</PageTitle>

<h1>Checkout</h1>

@if (cart is null || cart.Lines.Count == 0)
{
    <p>Your cart is empty.</p>
    <p><a class="btn-link" href="/cart">Return to cart</a></p>
}
else
{
    <EditForm Model="model" OnValidSubmit="SubmitAsync">
        <div class="form-grid">
            <label>
                Email
                <InputText @bind-Value="model.Email" />
            </label>
            <label>
                Shipping first name
                <InputText @bind-Value="model.ShippingFirstName" />
            </label>
            <label>
                Shipping last name
                <InputText @bind-Value="model.ShippingLastName" />
            </label>
            <label>
                Shipping street
                <InputText @bind-Value="model.ShippingStreet" />
            </label>
            <label>
                Shipping city
                <InputText @bind-Value="model.ShippingCity" />
            </label>
            <label>
                Shipping postal code
                <InputText @bind-Value="model.ShippingPostalCode" />
            </label>
            <label>
                Shipping country
                <InputText @bind-Value="model.ShippingCountry" />
            </label>
            <label>
                Shipping phone
                <InputText @bind-Value="model.ShippingPhone" />
            </label>
            <label>
                Billing first name
                <InputText @bind-Value="model.BillingFirstName" />
            </label>
            <label>
                Billing last name
                <InputText @bind-Value="model.BillingLastName" />
            </label>
            <label>
                Billing street
                <InputText @bind-Value="model.BillingStreet" />
            </label>
            <label>
                Billing city
                <InputText @bind-Value="model.BillingCity" />
            </label>
            <label>
                Billing postal code
                <InputText @bind-Value="model.BillingPostalCode" />
            </label>
            <label>
                Billing country
                <InputText @bind-Value="model.BillingCountry" />
            </label>
            <label>
                Billing phone
                <InputText @bind-Value="model.BillingPhone" />
            </label>
        </div>

        <section class="admin-panel">
            <h2>Shipping Method</h2>

            @if (isLoadingQuotes)
            {
                <p>Loading shipping options...</p>
            }
            else if (shippingQuotes.Count == 0)
            {
                <p>No shipping methods available for destination country.</p>
            }
            else
            {
                <div class="checkout-shipping-methods">
                    @foreach (var quote in shippingQuotes)
                    {
                        <label class="checkout-shipping-option">
                            <input
                                type="radio"
                                name="shipping-method"
                                value="@quote.Code"
                                checked="@(model.ShippingMethodCode == quote.Code)"
                                @onchange="(_)=> SelectShippingMethod(quote.Code)" />
                            <span>
                                <strong>@quote.Name</strong>
                                @if (!string.IsNullOrWhiteSpace(quote.Description))
                                {
                                    <span> - @quote.Description</span>
                                }
                                <span>
                                    @if (quote.IsFreeShipping)
                                    {
                                        <strong>Free</strong>
                                    }
                                    else
                                    {
                                        <strong>@FormatPrice(quote.PriceAmount, quote.Currency)</strong>
                                    }
                                </span>
                                @if (quote.EstimatedMinDays is not null || quote.EstimatedMaxDays is not null)
                                {
                                    <span>
                                        (ETA:
                                        @if (quote.EstimatedMinDays == quote.EstimatedMaxDays)
                                        {
                                            @($"{quote.EstimatedMinDays} days")
                                        }
                                        else
                                        {
                                            @($"{quote.EstimatedMinDays}-{quote.EstimatedMaxDays} days")
                                        })
                                    </span>
                                }
                            </span>
                        </label>
                    }
                </div>
            }

            <button class="btn-link" type="button" @onclick="RefreshQuotesAsync" disabled="@isLoadingQuotes">Refresh shipping methods</button>
        </section>

        <section class="admin-panel">
            <h2>Order Summary</h2>
            <p>Subtotal before discounts: <strong>@FormatPrice(cart.SubtotalBeforeDiscountAmount, currency)</strong></p>
            @if (cart.LineDiscountTotalAmount > 0m)
            {
                <p>Line discounts: <strong>-@FormatPrice(cart.LineDiscountTotalAmount, currency)</strong></p>
            }
            @if (cart.CartDiscountTotalAmount > 0m)
            {
                <p>Cart discounts: <strong>-@FormatPrice(cart.CartDiscountTotalAmount, currency)</strong></p>
            }
            @if (!string.IsNullOrWhiteSpace(cart.AppliedCouponCode))
            {
                <p>Coupon: <strong>@cart.AppliedCouponCode</strong></p>
            }
            <p>Cart subtotal: <strong>@FormatPrice(subtotalAmount, currency)</strong></p>
            <p>Shipping: <strong>@FormatShipping()</strong></p>
            <p>Total: <strong>@FormatPrice(subtotalAmount + selectedShippingAmount, currency)</strong></p>
        </section>

        <button class="btn-primary" type="submit" disabled="@isSubmitting">Place order</button>
    </EditForm>
}

@if (!string.IsNullOrWhiteSpace(message))
{
    <p class="status-message">@message</p>
}

@if (orderId is not null)
{
    <p>Order created: <strong>@orderId</strong></p>
    <p>Redirecting to payment...</p>
}

@code {
    private readonly CheckoutModel model = new();
    private bool isSubmitting;
    private bool isLoadingQuotes;
    private string? message;
    private Guid? orderId;
    private StoreCart? cart;
    private List<StoreShippingQuoteMethod> shippingQuotes = [];
    private decimal subtotalAmount;
    private decimal selectedShippingAmount;
    private string currency = "EUR";

    protected override async Task OnInitializedAsync()
    {
        var customerId = CustomerContext.GetCustomerId();
        cart = await StoreApiClient.GetCartAsync(customerId, CancellationToken.None);
        subtotalAmount = cart?.GrandTotalAmount ?? 0m;
        currency = cart?.Currency ?? "EUR";

        var profile = await StoreApiClient.GetCurrentCustomerAsync(CancellationToken.None);
        if (profile is null)
        {
            await LoadShippingQuotesAsync();
            return;
        }

        model.Email = profile.Email;
        model.ShippingFirstName = profile.FirstName ?? string.Empty;
        model.ShippingLastName = profile.LastName ?? string.Empty;
        model.BillingFirstName = model.ShippingFirstName;
        model.BillingLastName = model.ShippingLastName;
        model.ShippingPhone = profile.PhoneNumber;
        model.BillingPhone = profile.PhoneNumber;

        await LoadShippingQuotesAsync();
    }

    private async Task SubmitAsync()
    {
        isSubmitting = true;
        message = null;
        orderId = null;

        await LoadShippingQuotesAsync();

        if (shippingQuotes.Count == 0)
        {
            message = "No shipping methods are available for this destination.";
            isSubmitting = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(model.ShippingMethodCode))
        {
            message = "Select a shipping method before placing the order.";
            isSubmitting = false;
            return;
        }

        var cartSessionId = CustomerContext.GetCustomerId();
        var idempotencyKey = Guid.NewGuid().ToString("N");
        var request = new StoreCheckoutRequest(
            cartSessionId,
            model.Email,
            model.ShippingMethodCode,
            new StoreCheckoutAddress(
                model.ShippingFirstName,
                model.ShippingLastName,
                model.ShippingStreet,
                model.ShippingCity,
                model.ShippingPostalCode,
                model.ShippingCountry,
                model.ShippingPhone),
            new StoreCheckoutAddress(
                model.BillingFirstName,
                model.BillingLastName,
                model.BillingStreet,
                model.BillingCity,
                model.BillingPostalCode,
                model.BillingCountry,
                model.BillingPhone));

        var createdOrderId = await StoreApiClient.CheckoutAsync(request, idempotencyKey, CancellationToken.None);

        if (createdOrderId is null)
        {
            message = "Checkout could not be completed. Reservations may have expired, please refresh your cart.";
            isSubmitting = false;
            return;
        }

        orderId = createdOrderId;
        message = "Order created. Continue with payment.";
        CartState.SetItemCount(0);
        Navigation.NavigateTo($"/checkout/payment?orderId={createdOrderId:D}");
        isSubmitting = false;
    }

    private async Task RefreshQuotesAsync()
    {
        await LoadShippingQuotesAsync();
    }

    private async Task LoadShippingQuotesAsync()
    {
        subtotalAmount = cart?.GrandTotalAmount ?? subtotalAmount;
        isLoadingQuotes = true;
        shippingQuotes = [..await StoreApiClient.GetShippingQuotesAsync(
            model.ShippingCountry,
            subtotalAmount,
            currency,
            CancellationToken.None)];
        isLoadingQuotes = false;

        if (shippingQuotes.Count == 0)
        {
            model.ShippingMethodCode = null;
            selectedShippingAmount = 0m;
            return;
        }

        if (string.IsNullOrWhiteSpace(model.ShippingMethodCode) ||
            shippingQuotes.All(quote => !string.Equals(quote.Code, model.ShippingMethodCode, StringComparison.Ordinal)))
        {
            model.ShippingMethodCode = shippingQuotes[0].Code;
        }

        UpdateSelectedShippingAmount();
    }

    private void SelectShippingMethod(string shippingMethodCode)
    {
        model.ShippingMethodCode = shippingMethodCode;
        UpdateSelectedShippingAmount();
    }

    private void UpdateSelectedShippingAmount()
    {
        selectedShippingAmount = shippingQuotes
            .FirstOrDefault(quote => quote.Code == model.ShippingMethodCode)
            ?.PriceAmount ?? 0m;
    }

    private string FormatShipping()
    {
        return selectedShippingAmount == 0m ? "Free" : FormatPrice(selectedShippingAmount, currency);
    }

    private static string FormatPrice(decimal amount, string currentCurrency)
    {
        return string.Create(
            System.Globalization.CultureInfo.InvariantCulture,
            $"{amount:0.00} {currentCurrency.ToUpperInvariant()}");
    }

    private sealed class CheckoutModel
    {
        public string Email { get; set; } = string.Empty;

        public string? ShippingMethodCode { get; set; }

        public string ShippingFirstName { get; set; } = string.Empty;

        public string ShippingLastName { get; set; } = string.Empty;

        public string ShippingStreet { get; set; } = string.Empty;

        public string ShippingCity { get; set; } = string.Empty;

        public string ShippingPostalCode { get; set; } = string.Empty;

        public string ShippingCountry { get; set; } = "BG";

        public string? ShippingPhone { get; set; }

        public string BillingFirstName { get; set; } = string.Empty;

        public string BillingLastName { get; set; } = string.Empty;

        public string BillingStreet { get; set; } = string.Empty;

        public string BillingCity { get; set; } = string.Empty;

        public string BillingPostalCode { get; set; } = string.Empty;

        public string BillingCountry { get; set; } = "BG";

        public string? BillingPhone { get; set; }
    }
}

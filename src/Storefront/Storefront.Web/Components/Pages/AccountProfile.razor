@page "/account"
@page "/account/profile"
@layout Storefront.Web.Components.Layout.AccountLayout
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient

<PageTitle>Account Profile</PageTitle>

<section class="tech-panel account-page-intro">
    <p class="tech-eyebrow">Profile</p>
    <h1>Keep your client details ready for faster checkout, delivery updates, and follow-up support.</h1>
    <p class="tech-copy">Your core contact details stay here so every future order feels simpler, calmer, and easier to manage.</p>
</section>

@if (isLoading)
{
    <section class="tech-detail-card account-state-card">
        <p class="tech-eyebrow">Loading</p>
        <h2>Preparing your account profile</h2>
        <p>We are fetching your current details and checkout preferences.</p>
    </section>
}
else if (!isAuthenticated)
{
    <section class="tech-detail-card account-state-card">
        <p class="tech-eyebrow">Sign in required</p>
        <h2>Access your private client area</h2>
        <p>Sign in to review saved details, delivery information, and previous orders.</p>
        <div class="account-state-actions">
            <a class="tech-button tech-button-primary" href="/account/login">Sign in</a>
            <a class="tech-button tech-button-ghost" href="/account/register">Create account</a>
        </div>
        <p class="account-state-support">A private account keeps orders, saved addresses, and support history inside the same storefront experience.</p>
    </section>
}
else
{
    <section class="tech-detail-card account-form-card">
        <div class="tech-detail-card-header">
            <div>
                <p class="tech-eyebrow">Client details</p>
                <h2>Personal information</h2>
            </div>
        </div>

        <div class="account-detail-grid account-detail-grid-emphasis">
            <div>
                <span>Receipts</span>
                <strong>@profileModel.Email</strong>
            </div>
            <div>
                <span>Updates</span>
                <strong>@(string.IsNullOrWhiteSpace(profileModel.PhoneNumber) ? "Email only" : profileModel.PhoneNumber)</strong>
            </div>
            <div>
                <span>Checkout</span>
                <strong>Saved for faster completion</strong>
            </div>
        </div>

        <EditForm Model="profileModel" OnValidSubmit="SaveAsync">
            <div class="form-grid tech-form-grid">
                <label class="tech-field tech-field-full">
                    <span>Email</span>
                    <input value="@profileModel.Email" disabled />
                </label>
                <label class="tech-field">
                    <span>First name</span>
                    <InputText @bind-Value="profileModel.FirstName" />
                </label>
                <label class="tech-field">
                    <span>Last name</span>
                    <InputText @bind-Value="profileModel.LastName" />
                </label>
                <label class="tech-field tech-field-full">
                    <span>Phone</span>
                    <InputText @bind-Value="profileModel.PhoneNumber" />
                </label>
            </div>
            <div class="account-inline-actions">
                <button class="tech-button tech-button-primary" type="submit" disabled="@isSaving">Save profile</button>
                <p class="account-inline-note">Used for order updates, delivery contact, and smoother future checkout.</p>
            </div>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="status-message">@message</p>
        }
    </section>
}

@code {
    private readonly ProfileModel profileModel = new();
    private bool isLoading = true;
    private bool isSaving;
    private bool isAuthenticated;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        var customer = await StoreApiClient.GetCurrentCustomerAsync(CancellationToken.None);
        if (customer is null)
        {
            isAuthenticated = false;
            isLoading = false;
            return;
        }

        profileModel.Email = customer.Email;
        profileModel.FirstName = customer.FirstName ?? string.Empty;
        profileModel.LastName = customer.LastName ?? string.Empty;
        profileModel.PhoneNumber = customer.PhoneNumber ?? string.Empty;

        isAuthenticated = true;
        isLoading = false;
    }

    private async Task SaveAsync()
    {
        if (!isAuthenticated)
        {
            return;
        }

        isSaving = true;
        message = null;

        var success = await StoreApiClient.UpdateCurrentCustomerAsync(
            new StoreUpdateProfileRequest(
                profileModel.FirstName,
                profileModel.LastName,
                profileModel.PhoneNumber),
            CancellationToken.None);

        message = success ? "Profile updated." : "Unable to update profile.";
        isSaving = false;
    }

    private sealed class ProfileModel
    {
        public string Email { get; set; } = string.Empty;

        public string? FirstName { get; set; }

        public string? LastName { get; set; }

        public string? PhoneNumber { get; set; }
    }
}

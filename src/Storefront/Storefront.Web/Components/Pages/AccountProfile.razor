@page "/account"
@page "/account/profile"
@layout Storefront.Web.Components.Layout.AccountLayout
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient

<PageTitle>Account Profile</PageTitle>

@if (isLoading)
{
    <header class="account-page-header account-page-intro">
        <p class="account-eyebrow">Account</p>
        <h1>Profile</h1>
        <p>Manage your personal details and checkout contact information.</p>
    </header>

    <section class="account-card account-state-card">
        <h2>Loading profile</h2>
        <p>Fetching your account details.</p>
    </section>
}
else if (!isAuthenticated)
{
    <section class="account-card account-empty-state">
        <div class="account-empty-state-header">
            <p class="account-eyebrow">Account</p>
            <h1>Profile</h1>
            <p>Manage your personal details and checkout contact information.</p>
        </div>
        <div class="account-empty-prompt">
            <h2>Sign in to manage your profile</h2>
            <p>Use your account to view and update saved profile information.</p>
        </div>
        <div class="account-empty-actions">
            <a class="account-button account-button-primary" href="/account/login">Sign in</a>
            <a class="account-button account-button-secondary" href="/account/register">Create account</a>
        </div>
        <ul class="account-benefit-list" aria-label="Profile options after sign in">
            <li class="account-benefit-item">Review your saved contact details</li>
            <li class="account-benefit-item">Update your name and phone number</li>
            <li class="account-benefit-item">Keep checkout contact information current</li>
        </ul>
    </section>
}
else
{
    <header class="account-page-header account-page-intro">
        <p class="account-eyebrow">Account</p>
        <h1>Profile</h1>
        <p>Manage your personal details and checkout contact information.</p>
    </header>

    <section class="account-card account-form-card">
        <h2>Personal details</h2>

        <EditForm Model="profileModel" OnValidSubmit="SaveAsync" class="account-form">
            <div class="account-form-grid">
                <label class="account-field account-field-full">
                    <span>Email</span>
                    <input value="@profileModel.Email" disabled />
                </label>
                <label class="account-field">
                    <span>First name</span>
                    <InputText @bind-Value="profileModel.FirstName" />
                </label>
                <label class="account-field">
                    <span>Last name</span>
                    <InputText @bind-Value="profileModel.LastName" />
                </label>
                <label class="account-field account-field-full">
                    <span>Phone</span>
                    <InputText @bind-Value="profileModel.PhoneNumber" />
                </label>
            </div>
            <div class="account-inline-actions">
                <button class="account-button account-button-primary" type="submit" disabled="@isSaving">
                    @(isSaving ? "Saving..." : "Save changes")
                </button>
            </div>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="status-message">@message</p>
        }
    </section>
}

@code {
    private readonly ProfileModel profileModel = new();
    private bool isLoading = true;
    private bool isSaving;
    private bool isAuthenticated;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        var customer = await StoreApiClient.GetCurrentCustomerAsync(CancellationToken.None);
        if (customer is null)
        {
            isAuthenticated = false;
            isLoading = false;
            return;
        }

        profileModel.Email = customer.Email;
        profileModel.FirstName = customer.FirstName ?? string.Empty;
        profileModel.LastName = customer.LastName ?? string.Empty;
        profileModel.PhoneNumber = customer.PhoneNumber ?? string.Empty;

        isAuthenticated = true;
        isLoading = false;
    }

    private async Task SaveAsync()
    {
        if (!isAuthenticated)
        {
            return;
        }

        isSaving = true;
        message = null;

        var success = await StoreApiClient.UpdateCurrentCustomerAsync(
            new StoreUpdateProfileRequest(
                profileModel.FirstName,
                profileModel.LastName,
                profileModel.PhoneNumber),
            CancellationToken.None);

        message = success ? "Profile updated." : "Unable to update profile.";
        isSaving = false;
    }

    private sealed class ProfileModel
    {
        public string Email { get; set; } = string.Empty;

        public string? FirstName { get; set; }

        public string? LastName { get; set; }

        public string? PhoneNumber { get; set; }
    }
}

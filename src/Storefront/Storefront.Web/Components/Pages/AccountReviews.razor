@page "/account/reviews"
@layout Storefront.Web.Components.Layout.AccountLayout
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient

<PageTitle>My Reviews</PageTitle>

<section class="tech-panel account-page-intro">
    <p class="tech-eyebrow">Reviews</p>
    <h1>Review your submitted ratings, moderation status, and verified purchase notes in one place.</h1>
    <p class="tech-copy">Your product feedback remains readable and close to the rest of the storefront, not hidden behind a utility screen.</p>
</section>

@if (isLoading)
{
    <section class="tech-detail-card account-state-card">
        <p class="tech-eyebrow">Loading</p>
        <h2>Preparing your reviews</h2>
        <p>We are fetching submitted ratings and moderation status.</p>
    </section>
}
else if (!isAuthenticated)
{
    <section class="tech-detail-card account-state-card">
        <p class="tech-eyebrow">Sign in required</p>
        <h2>Access your submitted reviews</h2>
        <p>Sign in to manage feedback and see moderation status.</p>
        <a class="tech-button tech-button-primary" href="/account/login">Sign in</a>
    </section>
}
else if (reviews.Count == 0)
{
    <section class="tech-detail-card account-state-card">
        <p class="tech-eyebrow">Nothing submitted yet</p>
        <h2>Your product reviews will appear here.</h2>
        <p>Once you review a product, the rating and moderation status will be visible in this area.</p>
    </section>
}
else
{
    <div class="order-list">
        @foreach (var review in reviews)
        {
            <article class="order-card account-order-card">
                <header class="account-card-header">
                    <div>
                        <p class="tech-eyebrow">Product review</p>
                        <h2><a href="/product/@review.ProductSlug">@review.ProductName</a></h2>
                    </div>
                    <div class="account-card-meta">
                        <span class="tech-chip tech-chip-muted account-status-chip">@review.Status</span>
                        @if (review.IsVerifiedPurchase)
                        {
                            <span class="tech-chip tech-chip-success">Verified purchase</span>
                        }
                    </div>
                </header>
                <p class="tech-inline-meta">@review.CreatedAtUtc.ToString("yyyy-MM-dd")</p>
                <RatingStars Value="review.Rating" />
                @if (!string.IsNullOrWhiteSpace(review.Title))
                {
                    <h3>@review.Title</h3>
                }
                @if (!string.IsNullOrWhiteSpace(review.Body))
                {
                    <p>@review.Body</p>
                }
            </article>
        }
    </div>
}

@code {
    private IReadOnlyCollection<StoreMyReview> reviews = [];
    private bool isLoading = true;
    private bool isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        var customer = await StoreApiClient.GetCurrentCustomerAsync(CancellationToken.None);
        isAuthenticated = customer is not null;
        if (isAuthenticated)
        {
            reviews = await StoreApiClient.GetMyReviewsAsync(CancellationToken.None);
        }

        isLoading = false;
    }
}

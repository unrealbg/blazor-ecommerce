@page "/account/reviews"
@layout Storefront.Web.Components.Layout.AccountLayout
@using Storefront.Web.Services.Api
@inject IStoreApiClient StoreApiClient

<PageTitle>My Reviews</PageTitle>

@if (isLoading)
{
    <header class="account-page-header account-page-intro">
        <p class="account-eyebrow">Account</p>
        <h1>Reviews</h1>
        <p>Manage your product reviews.</p>
    </header>

    <section class="account-card account-state-card">
        <h2>Loading reviews</h2>
        <p>We are fetching submitted ratings and moderation status.</p>
    </section>
}
else if (!isAuthenticated)
{
    <section class="account-card account-empty-state">
        <div class="account-empty-state-header">
            <p class="account-eyebrow">Account</p>
            <h1>Reviews</h1>
            <p>Manage your product reviews.</p>
        </div>
        <div class="account-empty-prompt">
            <h2>Sign in to manage reviews</h2>
            <p>Use your account to see submitted reviews and moderation status.</p>
        </div>
        <div class="account-empty-actions">
            <a class="account-button account-button-primary" href="/account/login">Sign in</a>
            <a class="account-button account-button-secondary" href="/account/register">Create account</a>
        </div>
        <ul class="account-benefit-list" aria-label="Review options after sign in">
            <li class="account-benefit-item">View submitted product reviews</li>
            <li class="account-benefit-item">Check review status</li>
            <li class="account-benefit-item">Open reviewed products</li>
        </ul>
    </section>
}
else if (reviews.Count == 0)
{
    <header class="account-page-header account-page-intro">
        <p class="account-eyebrow">Account</p>
        <h1>Reviews</h1>
        <p>Manage your product reviews.</p>
    </header>

    <section class="account-card account-state-card">
        <h2>Your product reviews will appear here.</h2>
        <p>Once you review a product, the rating and moderation status will be visible in this area.</p>
        <div class="account-actions account-state-actions">
            <a class="account-button account-button-primary" href="/account/orders">Review recent orders</a>
            <a class="account-button account-button-secondary" href="/search">Browse products</a>
        </div>
    </section>
}
else
{
    <header class="account-page-header account-page-intro">
        <p class="account-eyebrow">Account</p>
        <h1>Reviews</h1>
        <p>Manage your product reviews.</p>
    </header>

    <div class="order-list">
        @foreach (var review in reviews)
        {
            <article class="account-card account-order-card">
                <header class="account-card-header">
                    <div>
                        <p class="account-eyebrow">Product review</p>
                        <h2><a href="/product/@review.ProductSlug">@review.ProductName</a></h2>
                    </div>
                    <div class="account-card-meta">
                        <span class="account-chip account-chip-muted account-status-chip">@review.Status</span>
                        @if (review.IsVerifiedPurchase)
                        {
                            <span class="account-chip account-chip-success">Verified purchase</span>
                        }
                    </div>
                </header>
                <p class="account-meta">@review.CreatedAtUtc.ToString("yyyy-MM-dd")</p>
                <RatingStars Value="review.Rating" />
                @if (!string.IsNullOrWhiteSpace(review.Title))
                {
                    <h3>@review.Title</h3>
                }
                @if (!string.IsNullOrWhiteSpace(review.Body))
                {
                    <p>@review.Body</p>
                }
                <div class="account-actions account-card-actions">
                    <a class="account-button account-button-secondary" href="/product/@review.ProductSlug">Open product</a>
                </div>
            </article>
        }
    </div>
}

@code {
    private IReadOnlyCollection<StoreMyReview> reviews = [];
    private bool isLoading = true;
    private bool isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        var customer = await StoreApiClient.GetCurrentCustomerAsync(CancellationToken.None);
        isAuthenticated = customer is not null;
        if (isAuthenticated)
        {
            reviews = await StoreApiClient.GetMyReviewsAsync(CancellationToken.None);
        }

        isLoading = false;
    }
}

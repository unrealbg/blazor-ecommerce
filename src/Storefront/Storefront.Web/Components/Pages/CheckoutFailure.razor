@page "/checkout/failure"

<PageTitle>Payment Failed</PageTitle>

<h1>Payment failed</h1>
<p>We could not complete your payment. You can retry from the payment step.</p>

@if (OrderId is not null)
{
    <p>Order: <strong>@OrderId</strong></p>
    <p><a class="btn-primary" href="@($"/checkout/payment?orderId={OrderId:D}")">Retry payment</a></p>
}

@if (PaymentIntentId is not null)
{
    <p>Payment intent: <strong>@PaymentIntentId</strong></p>
}

@code {
    [SupplyParameterFromQuery]
    public Guid? OrderId { get; set; }

    [SupplyParameterFromQuery]
    public Guid? PaymentIntentId { get; set; }
}

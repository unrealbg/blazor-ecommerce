@page "/checkout/failure"

<PageTitle>Payment Failed</PageTitle>

<div class="tech-checkout-page tech-flow-page">
    <section class="tech-page-intro">
        <p class="tech-eyebrow">Payment issue</p>
        <h1>We could not complete the payment.</h1>
        <p>You can return to the payment step, review the order, and try again.</p>
    </section>

    <CheckoutProgressHeader CurrentStep="3" Steps="checkoutSteps" />

    <section class="tech-detail-card tech-flow-card tech-flow-card-danger">
        <div class="tech-detail-card-header">
            <p class="tech-eyebrow">Payment status</p>
            <h2>The payment attempt did not complete.</h2>
        </div>

        <div class="tech-summary-list">
            @if (OrderId is not null)
            {
                <div class="tech-summary-row">
                    <span>Order reference</span>
                    <strong>@OrderId</strong>
                </div>
            }

            @if (PaymentIntentId is not null)
            {
                <div class="tech-summary-row">
                    <span>Payment intent</span>
                    <strong>@PaymentIntentId</strong>
                </div>
            }
        </div>

        <div class="tech-flow-actions">
            @if (OrderId is not null)
            {
                <a class="tech-button tech-button-primary" href="@($"/checkout/payment?orderId={OrderId:D}")">Retry payment</a>
            }
            <a class="tech-button tech-button-ghost" href="/checkout">Return to checkout</a>
        </div>
    </section>
</div>

@code {
    [SupplyParameterFromQuery]
    public Guid? OrderId { get; set; }

    [SupplyParameterFromQuery]
    public Guid? PaymentIntentId { get; set; }

    private readonly IReadOnlyList<string> checkoutSteps = ["Bag", "Shipping", "Payment", "Review"];
}

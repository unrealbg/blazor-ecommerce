<footer class="main-footer">
    <div class="shell-container main-footer-grid">
        <div class="main-footer-brand">
            <a class="brand-mark footer" href="/">ASTRA<span>/FLUX</span></a>
            <p>Audio, workspace, and accessory products with clear prices, stock status, and checkout in EUR.</p>
        </div>

        <section>
            <h2>Shop</h2>
            <ul>
                <li><a href="/category/all-products">All products</a></li>
                <li><a href="/category/audio">Audio</a></li>
                <li><a href="/category/workspace">Workspace</a></li>
                <li><a href="/category/accessories">Accessories</a></li>
            </ul>
        </section>

        <section>
            <h2>Support</h2>
            <ul>
                <li><a href="/account/orders">Track order</a></li>
                <li><a href="/checkout">Delivery & checkout</a></li>
                <li><a href="/account/profile">Returns</a></li>
                <li><a href="/account/profile">Account support</a></li>
            </ul>
        </section>

        <section>
            <h2>Company</h2>
            <ul>
                <li><a href="/blog">Journal</a></li>
                <li><a href="/p/about">About</a></li>
                <li><a href="/p/privacy">Privacy</a></li>
                <li><a href="/p/terms">Terms</a></li>
            </ul>
        </section>
    </div>

    <div class="shell-container main-footer-meta">
        <p>English storefront. EUR pricing. EU fulfilment.</p>
        <p>Build: @BuildLabel</p>
    </div>
</footer>

@code {
    [Parameter]
    public string BuildLabel { get; set; } = "dev";
}

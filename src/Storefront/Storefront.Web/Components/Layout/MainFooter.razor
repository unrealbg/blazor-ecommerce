<footer class="main-footer">
    <div class="shell-container main-footer-grid">
        <div class="main-footer-brand">
            <a class="brand-mark footer" href="/">ASTRA<span>/FLUX</span></a>
            <p>Premium audio, workspace systems, and accessories selected for calmer spaces, cleaner materials, and longer ownership.</p>
        </div>

        <section>
            <h2>Shop</h2>
            <ul>
                <li><a href="/">Flagship</a></li>
                <li><a href="/category/all-products">Audio</a></li>
                <li><a href="/search?q=workspace">Workspace</a></li>
                <li><a href="/search?q=accessories">Accessories</a></li>
            </ul>
        </section>

        <section>
            <h2>Support</h2>
            <ul>
                <li><a href="/account/orders">Track order</a></li>
                <li><a href="/checkout">Delivery & checkout</a></li>
                <li><a href="/account/profile">Returns & care</a></li>
                <li><a href="/account/profile">Client services</a></li>
            </ul>
        </section>

        <section>
            <h2>Company</h2>
            <ul>
                <li><a href="/blog">Journal</a></li>
                <li><a href="/p/about">About</a></li>
                <li><a href="/p/privacy">Privacy</a></li>
                <li><a href="/p/terms">Terms</a></li>
            </ul>
        </section>
    </div>

    <div class="shell-container main-footer-meta">
        <p>English storefront. EUR pricing. EU fulfilment.</p>
        <p>Build: @BuildLabel</p>
    </div>
</footer>

@code {
    [Parameter]
    public string BuildLabel { get; set; } = "dev";
}

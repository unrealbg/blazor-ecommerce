{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=blazor_ecommerce;Username=postgres;Password=postgres",
    "Redis": "localhost:16379"
  },
  "Authentication": {
    "Jwt": {
      "Authority": "https://auth.local/",
      "Audience": "blazor-ecommerce-api"
    }
  },
  "Outbox": {
    "BatchSize": 20,
    "PollingInterval": "00:00:05"
  },
  "Inventory": {
    "ReservationTtlMinutes": 30,
    "ExpirationSweepSeconds": 60,
    "RefreshReservationOnCartMutation": true,
    "RetryOnConcurrencyCount": 3,
    "ExposeExactStockPublicly": false
  },
  "Payments": {
    "DefaultProvider": "Demo",
    "PendingPaymentReservationHoldMinutes": 15,
    "WebhookProcessingRetryCount": 3,
    "RequireWebhookVerification": false,
    "Demo": {
      "AutoCaptureOnCreate": true,
      "SimulateRequiresAction": false,
      "SimulateFailureRate": 0.0
    },
    "Stripe": {
      "SecretKey": "",
      "PublishableKey": "",
      "WebhookSecret": ""
    }
  },
  "Shipping": {
    "DefaultCarrier": "DemoCarrier",
    "DefaultCurrency": "EUR",
    "AllowStorePickup": false,
    "QuoteCacheSeconds": 60,
    "DemoCarrier": {
      "AutoAdvanceStatuses": false,
      "BaseTrackingUrl": "http://localhost:5000/demo-tracking/"
    }
  },
  "Reviews": {
    "AutoApproveVerifiedPurchaseReviews": false,
    "AutoApproveQuestions": false,
    "AutoApproveOfficialAnswers": true,
    "RestrictReviewsToPurchasersOnly": false,
    "AutoHideReportThreshold": 999,
    "PublicCacheSeconds": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}
